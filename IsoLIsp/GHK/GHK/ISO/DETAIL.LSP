(defun control(/ wlist)
    (setq dcl_id (load_dialog "c:/ghk/iso/valist.dcl"))
    (if (not old_point)(setq old_point '(640 480)))
    (if (not (new_dialog "valist" dcl_id "" old_point))
        (exit)
    )
    (setq wlist
        (list  "    Gate VA"
               "    Glove VA"
               "    Check VA"
               "     Ball VA"
               "    Butter VA"
               "     Dia. VA"
               "    Needle VA"
               "     3 WAY VA"
        )
    )
    (if (not num1)(setq num1 "0"))
    (setq con-val 1)
    (cond ((= 1 future) (set_tile "zfuture1" "1"))
          ((= 0 future) (set_tile "zfuture2" "1"))
    )
    (action_tile "accept" "(progn (setq x $x y $y) (setq old_point (done_dialog 1)))")
    (action_tile "itemlist" "(control- (setq num1 $value))")
    (action_tile "zfuture1" "(setq future 1)(setq p-wedth1 (* 0.2 sk1))(setq p-wedth2 (* 0.3 sk1))(setq p-wedth3 (* 0.5 sk1))(setq p-wedth4 (* 0.7 sk1))")
    (action_tile "zfuture2" "(setq future 0)(setq p-wedth1 (* 0 sk1))(setq p-wedth2 (* 0 sk1))(setq p-wedth3 (* 0 sk1))(setq p-wedth4 (* 0 sk1))")
    (start_list "itemlist")
    (mapcar 'add_list wlist)
    (end_list)
    (set_tile "itemlist" num1)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (if (= ok 1)(control-1))
    (princ)
)

(defun control-(data)
    (setq vasel1 (+ (atoi data) 1))
)

(defun control-1()
    (setq job_direc 2)
    (if (= vasel1 nil)(setq vasel1 1))
    (if (= future 1)
        (if (= vasel1 5)
            (prompt " IS NOT SPEC SIZE ")
            (progn
                (IF (not i-blt)(load"c:/ghk/iso/fitting"))
                (i-blt)
            )
        )
    )
    (cond
        ((= vasel1 1)
            (IF (NOT i-gate)(load"c:/ghk/iso/i-valve"))(i-gate)
        )
        ((= vasel1 2)
            (IF (NOT i-glov)(load"c:/ghk/iso/i-valve"))(i-glov)
        )
        ((= vasel1 3)
            (IF (NOT i-che)(load"c:/ghk/iso/i-valve"))(i-che)
        )
        ((= vasel1 4)
            (IF (NOT i-ball)(load"c:/ghk/iso/i-valve"))(i-ball)
        )
        ((= vasel1 5)
            (IF (NOT i-but)(load"c:/ghk/iso/i-valve"))(i-but)
