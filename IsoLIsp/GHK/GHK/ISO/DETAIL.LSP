    (start_list "itemlist")
    (mapcar 'add_list wlist)
    (end_list)
    (set_tile "itemlist" num8)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (if (= ok 1)(valacc6-1))
    (princ)
)

