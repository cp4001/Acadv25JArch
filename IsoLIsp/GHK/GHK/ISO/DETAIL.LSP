(defun isomenuset()
    (setq dcl_id (load_dialog "c:/ghk/iso/valist.dcl"))
    (if (not old_point)(setq old_point '(640 480)))
    (if (not (new_dialog "menuset" dcl_id "" old_point))
        (exit)
    )
    (start_image "image1")
    (slide_image 0 0 (dimx_tile "image1") (dimy_tile "image1") "con-type")
    (end_image)
    (start_image "image2")
    (slide_image 0 0 (dimx_tile "image2") (dimy_tile "image2") "handwhil")
    (end_image)
    (start_image "image3")
    (slide_image 0 0 (dimx_tile "image3") (dimy_tile "image3") "txt-stl")
    (end_image)
    (start_image "image4")
    (slide_image 0 0 (dimx_tile "image4") (dimy_tile "image4") "valend")
    (end_image)
    (cond ((= 1 con-type) (set_tile "zcon1" "1"))
          ((= 2 con-type) (set_tile "zcon2" "1"))
    )
    (cond ((= 1 hand-type) (set_tile "zhand1" "1"))
          ((= 2 hand-type) (set_tile "zhand2" "1"))
    )
    (cond ((= 1 size-type) (set_tile "zsize1" "1"))
          ((= 2 size-type) (set_tile "zsize2" "1"))
    )
    (cond ((= 1 valend-type) (set_tile "zvalend1" "1"))
          ((= 2 valend-type) (set_tile "zvalend2" "1"))
    )
    (cond ((= 1 text-type) (set_tile "ztext1" "1"))
          ((= 2 text-type) (set_tile "ztext2" "1"))
    )
    (pset-s1)
    (action_tile "accept" "(progn (setq x $x y $y) (setq old_point (done_dialog 1)))")
    (action_tile "ansicode" "(setq ansi- 1 ks- 0)(pset-s1)")
    (action_tile "kscode"   "(setq ansi- 0 ks- 1)(pset-s1)")
    (action_tile "zhand1" "(setq hand-type 1)")
    (action_tile "zhand2" "(setq hand-type 2)")
    (action_tile "zsize1" "(setq size-type 1)")
    (action_tile "zsize2" "(setq size-type 2)")
    (action_tile "zcon1" "(setq con-type 1)")
    (action_tile "zcon2" "(setq con-type 2)")
    (action_tile "ztext1" "(setq text-type 1)")
    (action_tile "ztext2" "(setq text-type 2)")
    (action_tile "zvalend1" "(setq valend-type 1)")
    (action_tile "zvalend2" "(setq valend-type 2)")
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (princ)
)

