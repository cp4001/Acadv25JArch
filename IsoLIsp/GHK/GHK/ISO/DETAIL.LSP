(defun setiso1()
    (setq olderr *error* *error* ghkerr)
    (setvar "cmdecho" 0)
    (layer1)
    (graphscr)
    (if (= ghk nil)(setq ghk 150))
    (command "layer" "t" "*" "")
    (setq la (getvar "clayer"))
    (setq orth(getvar "orthomode"))
    (setq os(getvar "osmode"))
    (setq c_dwgname "UNNAME")
    (if (= c_class "None")
        (progn
            (c:ssspec)
            (resetiso)
        )
    )
)

