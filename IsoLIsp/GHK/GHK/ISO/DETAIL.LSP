(defun resetiso()
    (setvar "modemacro" (strcat "Layer:$(substr,$(getvar,clayer),1,8)"
                            " Spec : " (strcat "[" c_class "] ")
                            (if (= ghk nil) " Unselect Size" (strcat " " (rtos ghk 2 0) "A "))
                            " Rat:"(if (= rat "A") " 150#" (if (= rat "B") " 300#" (if (= rat "C") " 600#" (if (= rat "D") " 900#"))))
                            " Flg:"(if (= sd "SO") " SLIP ON" (if (= sd "LA") " LAP JOINT" (if (= sd "WN") " WELD NECK" (if (= sd "SW") " SOCK WELD" (if (= sd "SCR'D") " SCR'D" sd)))))
                            "  " (if (= future 1) " CONT. " (if (= future 0) " HIDDEN "))
                        )
    )
)

;Data file read
(defun sslist1 (file / fn n-line if1)
 (setq lst1 nil lst2 nil)
 (setq fn(open (strcat "c:/ghk/iso/" file".dat") "r"))
 (setq msg(read-line fn))
 (while (setq n-line(read-line fn))
        (setq if1(substr n-line 1 1))
        (cond ((= if1 "*")
               (setq lst1(cons (substr n-line 2) lst1))
              )
              ((= if1 "(")
               (setq lst2(cons (read n-line) lst2))
              )
        )
 )
 (setq lst1(reverse lst1) lst2(reverse lst2))
)

;Data file read
(defun sslist2 (file / fn n-line if1)
 (setq bmlst1 nil bmlst2 nil)
 (setq fn(open (strcat "c:/ghk/iso/" file".spc") "r"))
 (setq msg(read-line fn))
 (while (setq n-line(read-line fn))
        (setq if1(substr n-line 1 1))
        (cond ((= if1 "*")
               (setq bmlst1(cons (read (substr n-line 2)) bmlst1))
              )
              ((= if1 "(")
               (setq bmlst2(cons (read n-line) bmlst2))
              )
        )
 )
 (setq bmlst1(reverse bmlst1) bmlst2(reverse bmlst2))
)
(defun c:ssspec(/ lst1 lst2 lst21 list1 ok)
    (setq dcl_id (load_dialog "c:/ghk/iso/ssspec.dcl"))
    (if (not (new_dialog "ssspec" dcl_id))
        (exit)
    )
    (sslist1 "ssspec")
    (setq   list1 "0")
    (setq   c_class (nth 0 lst1))
    (action_tile "z_list"  "(sub_1 (setq list1 $value))")
    (start_list "z_list")
    (mapcar 'add_list lst1)
    (end_list)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (princ)
)

(defun sub_1(data)
    (setq   c_class (nth (atoi data)   lst1))
    (setq   lst21   (nth (atoi data)   lst2))
    (setq   rat     (nth 0 lst21))
    (setq   rat-txt (nth 1 lst21))
    (sslist2 c_class)
    (setq bmlst1- (nth 0 bmlst1))
    (setq endtype (atof (nth 0 bmlst1-)))
)

(defun ssbolt1(/ lst1 lst2 b-lst1 b-lst2 b-lst20 b-ghk)
    (setq dcl_id (load_dialog "c:/ghk/iso/ssspec.dcl"))
    (if (not (new_dialog "ssbolt" dcl_id))
        (exit)
    )
    (sslist1 "bolt")
    (setq b-ghk (strcat (ch-size ghk) (chr 34)))
    (setq b-lst1(nth (atoi sizenum) lst1))
    (setq b-lst2(nth (atoi sizenum) lst2))
    (if (not lenadd) (setq lenadd "100")  (if (/= lenadd  "100")  (setq lenadd lenadd)))
    (cond
        ((= rat "A")
            (setq b-lst20(nth 0 b-lst2))
        )
        ((= rat "B")
            (setq b-lst20(nth 1 b-lst2))
        )
        ((= rat "C")
            (setq b-lst20(nth 2 b-lst2))
        )
    )
    (setq b-qty(nth 0 b-lst20))
    (setq b-size(nth 1 b-lst20))
    (setq c_itemno "081")
    (sc1)
    (cond
        ((= sd "M")
            (setq b-len(nth 2 b-lst20))
        )
        ((= sd "S")
            (setq b-len(nth 3 b-lst20))
        )
    )
    (action_tile "zghk"    "(setq b-ghk $value)")
    (action_tile "zqty"    "(setq b-qty $value)")
    (action_tile "zsize"   "(setq b-size $value)")
    (action_tile "zlen"    "(setq b-len $value)")
    (action_tile "zlenadd" "(setq lenadd $value)")
    (set_tile "zghk" b-ghk)
    (set_tile "zqty" b-qty)
    (set_tile "zsize" b-size)
    (set_tile "zlen" b-len)
    (set_tile "zlenadd" lenadd)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (princ)
)

