        )
    )
)

(defun disc-cha(ch1 ch2 / qty1 qty2 text1 text2 text3)
    (setq qty1 1)
    (setq qty2 1)
    (while qty1
        (setq text1 (substr c_disc qty2 (strlen ch1)))
        (if (= ch1 text1)
            (progn
               (setq text2 (substr c_disc 1 (- qty2 1)))
               (setq text3 (substr c_disc (+ qty2 (strlen ch1))))
               (setq c_disc (strcat text2 ch2 text3))
               (setq qty1 nil)
            )
            (setq qty2 (+ qty2 1))
        )
    )
)

(defun ratchan()
    (if (/= rat1 nil)
        (cond
            ((= rat1 "A")
                (setq c_item (strcat c_item "1"))
                (disc-cha rat-txt "150#")
            )
            ((= rat1 "B")
                (setq c_item (strcat c_item "3"))
                (disc-cha rat-txt "300#")
            )
            ((= rat1 "C")
                (setq c_item (strcat c_item "6"))
                (disc-cha rat-txt "600#")
            )
            ((= rat1 "D")
                (setq c_item (strcat c_item "9"))
                (disc-cha rat-txt "900#")
            )
            ((= rat1 "E")
                (setq c_item (strcat c_item "15"))
                (disc-cha rat-txt "1500#")
            )
        )
    )
)
