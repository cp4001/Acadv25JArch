(defun textang (num / sty obl sset ptcny pscnt acnt slist enn)
    (if (= text-type 2)
        (setq slist '((1 "T1" 30)
                     (2 "T12" 330)
                     (3 "T1" 90)
                     (4 "T1" 330)
                     (5 "T12" 30)
                     (6 "T12" 90)
                     (7 "STANDARD" 0)
                     (8 "STANDARD" 90)
                     )
                     sty (nth 1 (assoc num slist))
                     obl (nth 2 (assoc num slist))
        )
        (setq slist '((1 "STANDARD" 30)
                     (2 "STANDARD" 330)
                     (3 "STANDARD" 90)
                     (4 "STANDARD" 330)
                     (5 "STANDARD" 30)
                     (6 "STANDARD" 90)
                     (7 "STANDARD" 0)
                     (8 "STANDARD" 90)
                     )
                     sty (nth 1 (assoc num slist))
                     obl (nth 2 (assoc num slist))
        )
 ) 
 (prompt "\nPICK TEXT TO CHANGE: ")
 (setq cor_sty (getvar "textstyle"))
 (setq sset (ssget) ptcnt 0 acnt 0 pscnt (sslength sset))
 (if (not (tblsearch "style" "t1"))
     (progn
        (command "filedia" "0")
        (command "style" "t1" "romans" "" "" "30" "" "" "")
        (command "filedia" "1")
     )
 )
 (if (not (tblsearch "style" "t12"))
     (progn
        (command "filedia" "0")
        (command "style" "t12" "romans" "" "" "-30" "" "" "")
        (command "filedia" "1")
     )
 )
 (while (< ptcnt pscnt)
    (if (= "TEXT" (cdr (assoc 0 (entget (setq enn (ssname sset ptcnt))))))
        (progn
           (command "change" enn "" "" "" sty "" obl "")
           (setq ptcnt (1+ ptcnt) acnt (1+ acnt) )
        )
        (setq ptcnt (1+ ptcnt) )
    )
 )
 (setvar "textstyle" cor_sty)
 (prompt (strcat "\n"(rtos acnt 2 0) " " (if (= acnt 1) "LINE WAS" "LINES WERE")  " CHANGED."))
)

