)
(defun p-cal3(/ ia aaa n-len l a b c d e f g h i a1 b1 c1 d1 e1 f1 g1
                  h1 i1 t-len1 d-1 b-1 t-sizeno dwg_no1 dwg_no2)
    (setvar "cmdecho" 0)
    (setvar "osmode" 0)
    (setq ia 0)
    (setq aaa(ssget "X" (list (cons 2 "GHKISO"))))
    (setq dwg_no1 (getvar "dwgname"))
    (setq dwg_no2 (getvar "dwgprefix"))
    (if (=  dwg_no2 (substr dwg_no1 1 (strlen dwg_no2)))
        (setq n-len (substr dwg_no1 (+ (strlen dwg_no2) 1)))
        (setq n-len dwg_no1)
    )
    (setq n-len (strcase n-len))
    (if(= ".DWG" (substr n-len (- (strlen n-len) 3)))
        (setq n-len (substr n-len 1 (- (strlen n-len) 4)))
    )
    (setq l(sslength aaa))
    (repeat l
        (setq a(ssname aaa ia))
        (setq a1 (entget a))
        (if (= "GHKISO" (cdr (assoc 2 a1)))
            (progn
                (sam-1)
                (setq t-len1(assoc 1 b1))
                (setq d-1(cons (car t-len1) n-len))
                (setq b-1 (subst d-1 t-len1 b1))
                (entmod b-1)
            )
        )
        (setq ia(+ 1 ia))
    )
    (command "regen")
)

(defun o_1(data)
    (setq   o_spec (nth (atoi data)   lst1))
)
(defun n_1(data)
    (setq   n_spec (nth (atoi data)   lst1))
)
(defun p-cal4(/ ia aaa l o_spec n_spec a b c d e f g h i c1 d1 e1 g1 h1
                i1 t-itemno t-sizeno bmlst1 bmlst2 bmlst1- bmlst2-
                bmlst20- bmlst21- n_spec n_disc r-spec new_ghk new_class
                c_itemno i_sock i_weld i_large endtype sd n_item r-item
                d-1 b-1)
    (setvar "cmdecho" 0)
    (setvar "osmode" 0)
    (setq ia 0)
    (setq aaa(ssget))
    (setq l(sslength aaa))
    (setq dcl_id (load_dialog "c:/ghk/iso/ssspec.dcl"))
    (if (not (new_dialog "specchange" dcl_id))
        (exit)
    )
    (sslist1 "ssspec")
    (setq   list1 "0")
;    (setq   c_class (nth 0 lst1))
    (action_tile "o_list"  "(o_1 (setq list1 $value))")
    (action_tile "n_list"  "(n_1 (setq list2 $value))")
    (start_list "o_list")
    (mapcar 'add_list lst1)
    (end_list)
    (start_list "n_list")
    (mapcar 'add_list lst1)
    (end_list)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (repeat l
        (setq a(ssname aaa ia))
        (setq a1 (entget a))
        (if (= "GHKISO" (cdr (assoc 2 a1)))
            (progn
                (sam-1)
                (if (= o_spec (cdr (assoc 1 c1)))
                    (progn
                        (setq n_disc nil)
                        (setq t-itemno(substr (cdr (assoc 1 h1)) 1 3))
                        (setq t-sizeno(cdr (assoc 1 i1)))
                        (sslist2 n_spec)
                        (setq bmlst1- (nth (atoi (substr t-itemno 1 2)) bmlst1))
                        (setq i_sock (nth 0 bmlst1-))
                        (setq i_weld (nth 1 bmlst1-))
                        (setq i_large (nth 2 bmlst1-))
                        (setq bmlst2- (nth (atoi (substr t-itemno 1 2)) bmlst2))
                        (setq bmlst20- (nth 0 bmlst2-))
                        (setq bmlst21- (nth 1 bmlst2-))
                        (if (and (> (atof t-sizeno) 0) (<= (atof t-sizeno) (atof i_sock)))
                            (setq n_disc (nth 0 bmlst20-))
                            (if (and (>= (atof t-sizeno) (atof i_sock)) (<= (atof t-sizeno) (atof i_weld)))
                                (setq n_disc (nth 1 bmlst20-))
                                (if (and (>= (atof t-sizeno) (atof i_weld)) (<= (atof t-sizeno) (atof i_large)))
                                    (setq n_disc (nth 2 bmlst20-))
                                )
                            )
                        )
                        (if (and (> (atof t-sizeno) 0) (<= (atof t-sizeno) (atof i_sock)))
                            (setq sd (nth 0 bmlst21-))
                            (if (and (>= (atof t-sizeno) (atof i_sock)) (<= (atof t-sizeno) (atof i_weld)))
                                (setq sd (nth 1 bmlst21-))
                                (if (and (>= (atof t-sizeno) (atof i_weld)) (<= (atof t-sizeno) (atof i_large)))
                                    (setq sd (nth 2 bmlst21-))
                                )
                            )
                        )
                        (if (= t-itemno "060")
                            (progn
                                (cond
                                    ((= sd "WN")
                                        (setq n_item "WNF")
                                    )
                                    ((= sd "SO")
                                        (setq n_item "SOF")
                                    )
                                    ((= sd "LA")
                                        (setq n_item "LJF")
                                    )
                                    ((= sd "SW")
                                        (setq n_item "SWF")
                                    )
                                )
                                (setq r-item(assoc 1 d1))
                                (setq d-1(cons (car r-item) n_item))
                                (setq b-1 (subst d-1 r-item d1))
                                (entmod b-1)
                            )
                        )
                        (if (= n_disc nil)
                            (progn
                                (setq n_disc " ")
                                (setq n_item "NOT IS ITEM")
                                (setq r-item(assoc 1 d1))
                                (setq d-1(cons (car r-item) n_item))
                                (setq b-1 (subst d-1 r-item d1))
                                (entmod b-1)
                            )
                        )
;                        (if (/= t-itemno "080")
;                            (progn
                                (setq r-spec(assoc 1 c1))
                                (setq d-1(cons (car r-spec) n_spec))
                                (setq b-1 (subst d-1 r-spec c1))
                                (entmod b-1)
                                (setq r-disc(assoc 1 g1))
                                (setq d-1(cons (car r-disc) n_disc))
                                (setq b-1 (subst d-1 r-disc g1))
                                (entmod b-1)
;                            )
;                        )
                    )
                )
            )
        )
        (setq ia(+ 1 ia))
    )
    (command "regen")
)

(defun p-cal5(/ n-len i sel en el text n-len aaa l a b c d e f g h i a1 b1 c1 d1 e1 f1 g1
                  h1 i1 t-len1 d-1 b-1 t-sizeno q_con jhg)
    (command "cmdecho" "0")
    (setq n-len 0)
    (setq i 0)
    (setq sel(ssget))
    (setq l(sslength sel))
    (repeat l
        (setq en(ssname sel i))
        (setq el (entget en))
        (if (= "TEXT" (cdr (assoc 0 el)))
            (progn
                (setq text (cdr (assoc 1 el)))
                (setq n-len(+ n-len (atof text)))
                (setq i(+ 1 i))
            )
        )
    )
    (setq n-len(rtos n-len 2 1))
    (prompt "\n Select Info Block  ")
    (setq aaa(ssget))
    (setq l(sslength aaa))
    (setq a(ssname aaa 0))
    (setq a1 (entget a))
    (if (= "GHKISO" (cdr (assoc 2 a1)))
        (progn
            (sam-1)
            (if (= "PIP" (cdr (assoc 1 d1)))
                (setq t-len1(assoc 1 f1))
            )
            (setq t-sizeno (cdr (assoc 1 i1)))
            (if (< 99 (atof t-sizeno))
                (progn
                    (if (not ftof)(load"c:/ghk/iso/iso-base"))
                    (ftof)
                )
            )
            (setq d-1 (cons (car t-len1) n-len))
            (setq b-1 (subst d-1 t-len1 f1))
            (entmod b-1)
        )
    )
    (setq q_con (strcase (getstring "\nDo you want to continue < Yes / No > { Default = Y }: ")))
    (if (= q_con "N")(setq jhg nil)(setq jhg 7))
    (while jhg
        (setq n-len 0)
        (setq i 0)
        (setq sel(ssget))
        (if (= sel nil)
            (setq jhg nil)
            (progn
                (setq l(sslength sel))
                (repeat l
                    (setq en(ssname sel i))
                    (setq el (entget en))
                    (if (= "TEXT" (cdr (assoc 0 el)))
                        (progn
                            (setq text (cdr (assoc 1 el)))
                            (setq n-len(+ n-len (atof text)))
                            (setq i(+ 1 i))
                        )
                    )
                )
                (setq n-len(rtos n-len 2 1))
                (prompt "\n Select Info Block  ")
                (setq aaa(ssget))
                (setq l(sslength aaa))
                (setq a(ssname aaa 0))
                (setq a1 (entget a))
                (if (= "GHKISO" (cdr (assoc 2 a1)))
                    (progn
                        (sam-1)
                        (if (= "PIP" (cdr (assoc 1 d1)))
                            (setq t-len1(assoc 1 f1))
                        )
                        (setq t-sizeno (cdr (assoc 1 i1)))
                        (if (< 99 (atof t-sizeno))
                            (progn
                                (ftof)
                            )
                        )
                        (setq d-1 (cons (car t-len1) n-len))
                        (setq b-1 (subst d-1 t-len1 f1))
                        (entmod b-1)
                    )
                )
            )
        )
    )
    (command "regen")
)

