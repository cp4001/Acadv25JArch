            (sam-1)
            (if (= "PIP" (cdr (assoc 1 d1)))
                (setq t-len1(assoc 1 f1))
            )
            (setq t-sizeno (cdr (assoc 1 i1)))
            (if (< 99 (atof t-sizeno))
                (progn
                    (if (not ftof)(load"c:/ghk/iso/iso-base"))
                    (ftof)
                )
            )
            (setq d-1 (cons (car t-len1) n-len))
            (setq b-1 (subst d-1 t-len1 f1))
            (entmod b-1)
        )
    )
    (setq q_con (strcase (getstring "\nDo you want to continue < Yes / No > { Default = Y }: ")))
    (if (= q_con "N")(setq jhg nil)(setq jhg 7))
    (while jhg
        (setq n-len 0)
        (setq i 0)
        (setq sel(ssget))
        (if (= sel nil)
            (setq jhg nil)
            (progn
                (setq l(sslength sel))
                (repeat l
                    (setq en(ssname sel i))
                    (setq el (entget en))
                    (if (= "TEXT" (cdr (assoc 0 el)))
                        (progn
                            (setq text (cdr (assoc 1 el)))
                            (setq n-len(+ n-len (atof text)))
                            (setq i(+ 1 i))
                        )
                    )
                )
                (setq n-len(rtos (* n-len 1000) 2 1))
                (prompt "\n Select Info Block  ")
                (setq aaa(ssget))
                (setq l(sslength aaa))
                (setq a(ssname aaa 0))
                (setq a1 (entget a))
                (if (= "GHKISO" (cdr (assoc 2 a1)))
                    (progn
                        (sam-1)
                        (if (= "PIP" (cdr (assoc 1 d1)))
                            (setq t-len1(assoc 1 f1))
                        )
                        (setq t-sizeno (cdr (assoc 1 i1)))
                        (if (< 99 (atof t-sizeno))
                            (progn
                                (ftof)
                            )
                        )
                        (setq d-1 (cons (car t-len1) n-len))
                        (setq b-1 (subst d-1 t-len1 f1))
                        (entmod b-1)
                    )
                )
            )
        )
    )
    (command "regen")
)

(defun lineno(/ dcl_id f-no s-no b-spec b-ghk b-el ok)
    (setq dcl_id (load_dialog "c:/ghk/iso/valist.dcl"))
    (if (not old_point)(setq old_point '(640 480)))
    (if (not (new_dialog "lineno" dcl_id "" old_point))
        (exit)
    )
    (setq f-no "0-63200-")
    (setq s-no c_dwgname)
    (setq b-spec c_class)
    (setq b-ghk (rtos ghk 2 0))
    (setq b-el "2500")
    (if (not el-type)(setq el-type 1))
    (cond ((= 1 el-type) (set_tile "zeltype1" "1"))
          ((= 0 el-type) (set_tile "zeltype2" "1"))
    )
    (action_tile "accept" "(progn (setq x $x y $y) (setq old_point (done_dialog 1)))")
    (action_tile "zfno"    "(setq f-no $value)")
    (action_tile "zsno"    "(setq s-no $value)")
    (action_tile "zspec"   "(setq b-spec $value)")
    (action_tile "zghk"    "(setq b-ghk $value)")
    (action_tile "zel"     "(setq b-el $value)")
    (action_tile "zeltype1" "(setq el-type 1)")
    (action_tile "zeltype2" "(setq el-type 0)")
    (mode_tile "zsno" 2)
    (set_tile "zfno" f-no)
    (set_tile "zsno" s-no)
    (set_tile "zspec" b-spec)
    (set_tile "zghk" b-ghk)
    (set_tile "zel" b-el)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (if (= ok 1)(line_act))
    (princ)
)


(defun line_act(/ pt1 pt2 ang cor_sty li-no li-el textlen pt3 pt4 pt5
                  pt6 pt7 pt8)
    (setiso1)
    (setvar "osmode" 33)
    (SETQ pt1 (GETPOINT     "\nSTART POINT  : "))
    (setvar "osmode" 0)
    (setq pt2 (GETPOINT pt1 "\nSECOND POINT : "))
    (setq ang (angle pt1 pt2))
    (setq cor_sty (getvar "textstyle"))
    (setvar "textstyle" "standard")
    (setq li-no (strcat f-no s-no "-" b-spec "-" b-ghk))
    (cond ((= 1 el-type) (setq li-el (strcat "BOP EL." b-el)))
          ((= 0 el-type) (setq li-el (strcat "EL." b-el)))
    )
    (setq textlen(* (strlen li-no) s 2))
    (setq pt3 (POLAR pt1 ang (* 2 s)))
    (setq pt4 (POLAR pt3 (+ ang (dtr 90)) (* 0.5 s)))
    (setq pt5 (POLAR pt3 (+ ang (dtr 270)) (* 4 s)))
    (setq pt6 (POLAR pt1 ang textlen))
    (setq pt7 (POLAR pt6 (+ ang (dtr 90)) (* 1.5 s)))
    (setq pt8 (POLAR pt6 (+ ang (dtr 270)) (* 3 s)))
    (command "layer" "s" "2c" "")
    (line_act1)
    (command "line" pt3 pt6 "")
    (setvar "textstyle" cor_sty)
    (setiso2)
)




(defun line_act1()
    (if (= text-type 2)
        (progn
            (if (not (tblsearch "style" "t1"))
                (progn
                    (command "filedia" "0")
                    (command "style" "t1" "romans" "" "" "30" "" "" "")
                    (command "filedia" "1")
                )
            )
            (if (not (tblsearch "style" "t12"))
                (progn
                    (command "filedia" "0")
                    (command "style" "t12" "romans" "" "" "-30" "" "" "")
                    (command "filedia" "1")
                )
           )
        )
    )
    (cond
        ((and (>= (rtd ang) 15) (<= (rtd ang) 60))
            (if (= text-type 2)
                (setvar "textstyle" "t1")
                (setvar "textstyle" "standard")
            )
            (command "text" "bl" pt4 (* txt-h s) (rtd ang) li-no)
            (command "text" "bl" pt5 (* txt-h s) (rtd ang) li-el)
        )
        ((and (>= (rtd ang) 61) (<= (rtd ang) 120))
            (if (= text-type 2)
                (setvar "textstyle" "t12")
                (setvar "textstyle" "standard")
            )
            (command "text" "bl" pt4 (* txt-h s) (rtd ang) li-no)
            (command "text" "bl" pt5 (* txt-h s) (rtd ang) li-el)
         )
        ((and (>= (rtd ang) 121) (<= (rtd ang) 180))
            (if (= text-type 2)
                (setvar "textstyle" "t1")
                (setvar "textstyle" "standard")
            )
            (command "text" "tl" pt8 (* txt-h s) (+ (rtd ang) 180) li-no)
            (command "text" "tl" pt7 (* txt-h s) (+ (rtd ang) 180) li-el)
        )
        ((and (>= (rtd ang) 181) (<= (rtd ang) 240))
            (if (= text-type 2)
                (setvar "textstyle" "t1")
                (setvar "textstyle" "standard")
            )
            (command "text" "tl" pt8 (* txt-h s) (+ (rtd ang) 180) li-no)
            (command "text" "tl" pt7 (* txt-h s) (+ (rtd ang) 180) li-el)
        )
        ((and (>= (rtd ang) 241) (<= (rtd ang) 300))
            (if (= text-type 2)
                (setvar "textstyle" "t12")
                (setvar "textstyle" "standard")
            )
            (command "text" "tl" pt8 (* txt-h s) (+ (rtd ang) 180) li-no)
            (command "text" "tl" pt7 (* txt-h s) (+ (rtd ang) 180) li-el)
        )
        ((and (>= (rtd ang) 301) (<= (rtd ang) 360))
            (if (= text-type 2)
                (setvar "textstyle" "t12")
                (setvar "textstyle" "standard")
            )
            (command "text" "bl" pt4 (* txt-h s) (rtd ang) li-no)
            (command "text" "bl" pt5 (* txt-h s) (rtd ang) li-el)
        )
    )
)
