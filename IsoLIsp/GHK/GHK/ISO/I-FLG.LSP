(defun i-flg(/ flglen piplen pt1 pt2 pt3 pt3a pt3b pt3c pt3d pt4 pt4a pt4b
               pt5a pt5b pt6a pt6b pt7 pt7a pt7b pt7c pt7d pt8a pt8b pt8c
               pt9d ang)
    (setiso1)
    (setq c_itemno "060")
    (sc1)
    (flgtypesec)
    (if (= c_disc "")
        (prompt "\nIS NOT SPEC SIZE ")
        (progn
            (i-flg-1)
            (i-flg-2)
        )
    )
    (setiso2)
    (setq old_sd sd)
    (if (/= job_direc1 0)(val-acc))
    (prin1)
)

(defun i-flg-1()
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (setq pt1 (GETPOINT "\nPICK START POINT OF SLIP ON FLANGE : "))
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setvar "osmode" 0)
            (setq ang (GETANGLE pt1 "\nPICK 2nd OF SLIP ON FLANGE  DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (if (= sd "LA")
        (setq pt2 (POLAR pt1 ang (* 3.7 sk1)))
        (if (or (= sd "SW") (= sd "SCR'D"))
            (setq pt2 (POLAR pt1 ang (* 0.15 sk1)))
            (setq pt2 (POLAR pt1 ang (* 3 sk1)))
        )
    )
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
    )
)

(defun i-flg-2()
    (ratchan)
    (setq pt3 (POLAR pt2 (+ ang (dtr 180)) flgwidth))
    (setq pt4 (POLAR pt2 ang flgwidth))
    (setq pt3a(POLAR pt3 ang1 flglen))
    (setq pt3b(POLAR pt3 (+ ang1 (dtr 180)) flglen))
    (setq pt3c(POLAR pt3 ang1 piplen))
    (setq pt3d(POLAR pt3 (+ ang1 (dtr 180)) piplen))
    (setq pt4a(POLAR pt4 ang1 flglen))
    (setq pt4b(POLAR pt4 (+ ang1 (dtr 180)) flglen))
    (setq pt5a(POLAR pt4 ang1 (* flglen 0.6)))
    (setq pt5b(POLAR pt4 (+ ang1 (dtr 180)) (* flglen 0.6)))
    (setq pt6a(POLAR pt3 ang1 (* flglen 0.6)))
    (setq pt6b(POLAR pt3 (+ ang1 (dtr 180)) (* flglen 0.6)))
    (setq pt7 (POLAR pt2 (+ ang (dtr 180)) (+ (* flgwidth 2) (* 0.95 sk1))))
    (setq pt7a(POLAR pt7 ang1 flglen))
    (setq pt7b(POLAR pt7 (+ ang1 (dtr 180)) flglen))
    (setq pt7c(POLAR pt7 ang1 piplen))
    (setq pt7d(POLAR pt7 (+ ang1 (dtr 180)) piplen))
    (setq pt8 (POLAR pt2 (+ ang (dtr 180)) (* 0.95 sk1)))
    (setq pt8a(POLAR pt8 ang1 flglen))
    (setq pt8b(POLAR pt8 (+ ang1 (dtr 180)) flglen))
    (setq pt8c(POLAR pt8 ang1 piplen))
    (setq pt8d(POLAR pt8 (+ ang1 (dtr 180)) piplen))
    (if (or (= sd "SW")(= sd "SCR'D"))
        (command "layer" "s" "5c" "")
        (command "layer" "s" "8c" "")
    )
    (cond
        ((= sd "WN")
            (cond
                ((= future 1)
                    (command "solid" pt3c pt1 pt3d "" "")
                    (command "insert" "c:/ghk/iso/isoweld" pt1 sk1 "" "")
                    (if (= dwgtype "D")
                        (command "pline" pt3b "w" "0" "0" pt4b pt3a pt4a "c")
                        (command "solid" pt3b pt4b pt3a pt4a "")
                    )
                    (if (/= dwgtype "D")(bmlist pt3))
                )
                ((= future 0)
                    (command "layer" "s" "2h" "")
                    (command "pline" pt3c "w" "0" "0" pt1 pt3d "")
                    (command "pline" pt3b "w" "0" "0" pt4b pt4a pt3a "c")
                    (command "circle" pt1 sk1)
                )
            )
        )
        ((= sd "SO")
            (cond
                ((= future 1)
                    (command "pline" pt1 "w" p-wedth4 p-wedth4 pt2 "")
                    (if (= dwgtype "D")
                        (command "pline" pt3b "w" "0" "0" pt4b pt3a pt4a "c")
                        (command "solid" pt3b pt4b pt3a pt4a "")
                    )
                    (if (/= dwgtype "D")(bmlist pt3))
                )
                ((= future 0)
                    (command "layer" "s" "2h" "")
                    (command "pline" pt1 "w" "0" "0" pt2 "")
                    (command "pline" pt3b "w" "0" "0" pt4b pt4a pt3a "c")
                )
            )
        )
        ((= sd "LA")
            (cond
                ((= future 1)
                    (command "pline" pt1 "w" p-wedth4 p-wedth4 pt2 "")
                    (if (= dwgtype "D")
                        (progn
                            (command "pline" pt5b "w" "0" "0" pt6b pt5a pt6a "c")
                            (command "pline" pt7b "w" "0" "0" pt8b pt7d pt8d "c")
                            (command "pline" pt7c "w" "0" "0" pt8c pt7a pt8a "c")
                        )
                        (progn
                            (command "solid" pt5b pt6b pt5a pt6a "")
                            (command "solid" pt7b pt8b pt7d pt8d "")
                            (command "solid" pt7c pt8c pt7a pt8a "")
                        )
                    )
                    (command "insert" "c:/ghk/iso/isoweld" pt1 sk1 "" "")
                    (if (/= dwgtype "D")(bmlist pt3))
                    (setq c_item "STE")
                    (setq c_itemno "020")
                    (sc1)
                    (if (/= dwgtype "D")(bmlist pt3))
                )
                ((= future 0)
                    (command "layer" "s" "2h" "")
                    (command "pline" pt1 "w" "0" "0" pt2 "")
                    (command "pline" pt5b "w" "0" "0" pt6b pt6a pt5a "c")
                    (command "pline" pt7b "w" "0" "0" pt8b pt8d pt7d "c")
                    (command "pline" pt7c "w" "0" "0" pt8c pt8a pt7a "c")
                    (command "circle" pt1 sk1)
                )
            )
        )
        ((or (= sd "SW")(= sd "SCR'D"))
            (cond
                ((= future 1)
                    (if (= dwgtype "D")
                        (command "pline" pt3b "w" "0" "0" pt4b pt3a pt4a "c")
                        (command "solid" pt3b pt4b pt3a pt4a "")
                    )
                    (if (/= dwgtype "D")(bmlist pt3))
                )
                ((= future 0)
                    (command "layer" "s" "2h" "")
                    (command "pline" pt3b "w" "0" "0" pt4b pt4a pt3a "c")
                )
            )
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" pt1 (POLAR pt2 ang (* 0.75 sk1)) "")
    (setq endpoint (POLAR pt2 ang (* 0.75 sk1)))
    (setq endang (angle pt1 pt2))
    (setq endang1 ang1)
)

