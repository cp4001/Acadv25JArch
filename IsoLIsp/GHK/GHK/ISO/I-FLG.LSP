    (prin1)
)

(defun i-flg5(/ flglen piplen pt1 pt2 pt1a pt1b pt1c pt1d)
    (setiso1)
    (setq c_itemno "050")
    (sc1)
    (flgtypesec)
    (setq c_item "SPB")
    (if (= c_disc "")
        (prompt "\nIS NOT SPEC SIZE ")
        (progn
            (i-flg5-1)
        )
    )
    (setiso2)
    (setq old_sd sd)
    (val-acc)
    (prin1)
)

(defun i-flg5-1()
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (setq pt1 (GETPOINT "\nPICK START POINT OF SLIP ON FLANGE : "))
            (IF (= pt1 nil)(setq pt1 (POLAR endpoint endang (* 0.75 sk1))))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 (POLAR endpoint endang (* 0.75 sk1))))
    (setq pt2 (POLAR pt1 endang (* 0.75 sk1)))
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
    (if (and (<= ang1 (+ endang (dtr 10))) (>= ang1 (- endang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
    )
    (setq pt1a(POLAR pt1 ang1 (+ flglen (* 1 sk1))))
    (setq pt1b(POLAR pt1 (+ ang1 (dtr 180)) flglen))
    (setq pt1c(POLAR pt1a ang1 sk1))
    (setq pt1d(POLAR pt1c ang1 (* sk1 2)))
    (ratchan)
    (cond
        ((= future 1)
            (command "layer" "s" "2c" "")
            (command "pline" pt1b "w" p-wedth3 p-wedth3 pt1c "")
            (command "insert" "c:/ghk/iso/isoweld" pt1c sk1 "" "")
            (command "circle" pt1c sk1)
            (command "circle" pt1d sk1)
            (setq c_itemno (strcat c_itemno "1"))
            (if (/= dwgtype "D")(bmlist pt1b))
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
            (command "pline" pt1b "w" "0" "0" pt1c "")
            (command "circle" pt1c sk1)
            (command "circle" pt1d sk1)
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" (POLAR pt1 (+ endang (dtr 180)) (* 0.75 sk1))  pt2 "")
    (setq endpoint pt2)
)

(defun i-flg6(/ flglen piplen pt1 pt2 pt1a pt1b)
    (setiso1)
    (setq c_itemno "060")
    (sc1)
    (flgtypesec)
    (if (= c_disc "")
        (prompt "\nIS NOT SPEC SIZE ")
        (progn
            (setq job_direc1 0)
            (i-flg)
            (setq job_direc1 nil)
            (setq job_direc 2)
            (i-gas)
            (setq old_sd "WAFER")
            (i-flg6-1)
            (IF (not pi-tag)(load"c:/ghk/iso/fitting"))(pi-tag)
            (i-flg1)
        )
    )
    (setiso2)
    (setq old_sd sd)
    (prin1)
)

(defun i-flg6-1()
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 (POLAR endpoint endang (* 0.75 sk1))))
    (setq pt2 (POLAR pt1 endang (* 0.75 sk1)))
    (setq ang1 endang1)
    (setq pt1a(POLAR pt1 ang1 piplen))
    (setq pt1b(POLAR pt1 (+ ang1 (dtr 180)) piplen))
    (cond
        ((= future 1)
            (command "layer" "s" "2c" "")
            (command "pline" pt1a "w" p-wedth3 p-wedth3 pt1b "")
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
            (command "pline" pt1a "w" "0" "0" pt1b "")
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" (POLAR pt1 (+ endang (dtr 180)) (* 0.75 sk1))  pt2 "")
    (setq endpoint pt2)
)

(defun flgtypesec()
    (cond
        ((= sd "WN")
            (setq c_item "WNF")
        )
        ((= sd "SO")
            (setq c_item "SOF")
        )
        ((= sd "LA")
            (setq c_item "LJF")
        )
        ((= sd "SW")
            (setq c_item "SWF")
        )
        ((= sd "SCR'D")
            (setq c_item "SCF")
        )
    )
;    (if (or (= sd "SW")(= sd "SCR'D"))
    (if (< ghk 49)
        (progn
            (setq flglen (* 3 sk1))
            (setq piplen (* 1.5 sk1))
            (setq flgwidth (* 1.25 p-wedth1))
        )
        (progn
            (setq flglen (* 5 sk1))
            (setq piplen (* 2.5 sk1))
            (setq flgwidth (* 1.75 p-wedth1))
        )
    )
)
