(defun i-flg3(/ flglen piplen pt1 pt1a pt1b pt1c pt2 pt3 pt3a pt3b pt3c
                pt3d pt4 pt4a pt4b ang)
    (setiso1)
    (setq c_itemno "060")
    (sc1)
    (flgtypesec)
    (setvar "osmode" 1)
    (SETQ pt1 (GETPOINT "\nPICK START POINT OF SLIP ON FLANGE : "))
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (setq ang (GETANGLE pt1 "\nPICK 2nd OF SLIP ON FLANGE  DIRECTION: "))
    (IF (= ang nil)(setq ang endang))
    (setq pt2 (POLAR pt1 ang (* 10 sk1)))
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
    )
    (setq pt1c(POLAR pt1 ang flglen))
    (setq pt1a(POLAR pt1c ang1 piplen))
    (setq pt1b(POLAR pt1c (+ ang1 (dtr 180)) piplen))
    (setq pt3 (POLAR pt2 ang (/ piplen 6)))
    (setq pt4 (POLAR pt2 (+ ang (dtr 180)) (/ piplen 2)))
    (setq pt3a(POLAR pt3 ang1 flglen))
    (setq pt3b(POLAR pt3 (+ ang1 (dtr 180)) flglen))
    (setq pt4a(POLAR pt4 ang1 flglen))
    (setq pt4b(POLAR pt4 (+ ang1 (dtr 180)) flglen))
    (setq pt4c(POLAR pt4 ang1 piplen))
    (setq pt4d(POLAR pt4 (+ ang1 (dtr 180)) piplen))
    (cond
        ((= future 1)
            (command "layer" "s" "2c" "")
            (command "pline" pt1b "w" "0" "0" pt4d pt4a pt3a pt3b pt4b pt4c pt1a "")
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
            (command "pline" pt1b "w" "0" "0" pt4d pt4a pt3a pt3b pt4b pt4c pt1a "")
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" pt1 (POLAR pt2 ang (* 0.75 sk1)) "")
    (setq endpoint (POLAR pt2 ang (* 0.75 sk1)))
    (setq endang (angle pt1 pt2))
    (setiso2)
    (if (or (= sd "SW") (= sd "SCR'D"))(val-acc6)(val-acc))
    (setq old_sd sd)
    (prin1)
)

