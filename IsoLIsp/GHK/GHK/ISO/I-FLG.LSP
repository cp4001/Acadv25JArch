;;;;blind flange
(defun i-flg2(/ flglen piplen old_ghk pt1 pt2 pt3 pt3a pt3b pt4 pt4a pt4b
                ang)
    (setiso1)
    (setq c_item "BLF")
    (setq c_itemno "060")
    (sc1)
    (set-selec i-flg2-1)
    (setiso2)
    (setq old_sd sd)
    (prin1)
)

(defun i-flg2-1()
    (if (= job_direc 2)(progn (i-gas)(i-blt)))
    (setq c_item "BLF")
    (setq c_itemno "060")
    (sc1)
    (disc-cha sd "BLIND")
    (if (or (= sd "SW")(= sd "SCR'D"))
        (progn
            (setq flglen (* 3 sk1))
            (setq piplen (* 1.5 sk1))
            (setq flgwidth (* 1.25 p-wedth1))
        )
        (progn
            (setq flglen (* 5 sk1))
            (setq piplen (* 2.5 sk1))
            (setq flgwidth (* 1.75 p-wedth1))
        )
    )
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (SETQ pt1 (GETPOINT "\nPICK START POINT OF SLIP ON FLANGE : "))
            (setvar "osmode" 0)
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setq ang (GETANGLE pt1 "\nPICK 2nd OF SLIP ON FLANGE  DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (setq pt1 (POLAR pt1 ang (* 0.75 sk1)))
    (setq pt2 (POLAR pt1 ang (* 0.75 sk1)))
    (if (= job_direc 1)
        (progn
            (initget 1)
            (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
            (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
                (setq ang1 (GETANGLE pt1 "\nPICK OF SLIP ON FLANGE DIRECTION: "))
            )
        )
    )
    (ratchan)
    (setq pt3 (POLAR pt1 (+ ang (dtr 180)) flgwidth))
    (setq pt3a(POLAR pt3 ang1 flglen))
    (setq pt3b(POLAR pt3 (+ ang1 (dtr 180)) flglen))
    (setq pt4 (POLAR pt1 ang flgwidth))
    (setq pt4a(POLAR pt4 ang1 flglen))
    (setq pt4b(POLAR pt4 (+ ang1 (dtr 180)) flglen))
    (if (or (= sd "SW")(= sd "SCR'D"))
        (command "layer" "s" "5c" "")
        (command "layer" "s" "8c" "")
    )
    (cond
        ((= future 1)
            (if (= dwgtype "D")
                (command "pline" pt3b "w" "0" "0" pt4b pt3a pt4a "c")
                (command "solid" pt3b pt4b pt3a pt4a "")
            )
            (if (/= dwgtype "D")(bmlist pt3))
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
            (command "pline" pt3b "w" "0" "0" pt4b pt4a pt3a "c")
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" pt1 pt2 "")
    (setq endpoint pt1)
    (setq endang (angle pt1 pt2))
)
