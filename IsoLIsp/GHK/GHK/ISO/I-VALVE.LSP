             (POLAR pt2 ang1 flglen)
             (POLAR pt2 (+ ang1 (dtr 180)) flglen)
             (POLAR (polar pt1 ang (/ (distance pt1 pt2) 2.00)) ang1 flglen)
             (POLAR pt1 (+ ang1 (dtr 180)) flglen) "c"
    )
    (if (= valend-type 1)
        (i-valve2)
    )
    (ratchan)
    (if (and (= future 1)(= con-val nil))
        (if (/= dwgtype "D")(bmlist (POLAR pt1 ang (/ (distance pt1 pt2) 2))))
    )
    (i-valve1)
)

(defun i-valve()
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF VALVE : "))
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setvar "osmode" 0)
            (setq ang (GETANGLE pt1 "\nPICK 2nd VALVE DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (if (or (= sd "BW") (and (= sd "SW") (= valend-type 2) (= con-val nil)))
        (setq pt1 pt1)
        (setq pt1 (POLAR pt1 ang (* 0.75 sk1)))
    )
    (if (or (= ventdr 1) (= ventdr 2))
        (progn
            (setq pt2 (POLAR pt1 ang (* 6 sk1)))
            (setq flglen (* 2 sk1))
            (setq piplen (* 1 sk1))
        )
        (if (< ghk 49)
            (progn
                (if (= sd "WAFER")
                    (setq pt2 (POLAR pt1 ang (* 4 sk1)))
                    (setq pt2 (POLAR pt1 ang (* 8 sk1)))
                )
                (setq flglen (* 3 sk1))
                (setq piplen (* 1.5 sk1))
            )
            (progn
                (if (= sd "WAFER")
                    (setq pt2 (POLAR pt1 ang (* 6 sk1)))
                    (setq pt2 (POLAR pt1 ang (* 11 sk1)))
                )
                (setq flglen (* 5 sk1))
                (setq piplen (* 2.5 sk1))
            )
        )
    )
    (initget 1)
    (setq ang1 (GETANGLE pt2 "\nPICK VALVE DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt2 "\nPICK VALVE DIRECTION: "))
    )
    (if (= future 1)
        (command "layer" "s" "2c" "")
        (command "layer" "s" "2h" "")
    )
)

(defun i-while(/ ptw2 ptw3 ptw2a ptw2b)
    (if (or (= ventdr 1) (= ventdr 2))
        (progn
            (setq ptw1 (POLAR pt1 ang (* 3 sk1)))
            (setq ptw2 (POLAR ptw1 ang1 (* 8 sk1)))
            (setq ptw3 (POLAR ptw2 ang1 (* 1.5 sk1)))
            (setq ptw2a(POLAR ptw2 (+ ang (dtr 180)) (* 3 sk1)))
            (setq ptw2b(POLAR ptw2 ang (* 3 sk1)))
        )
        (if (< ghk 49)
            (progn
                (setq ptw1 (POLAR pt1 ang (* 4 sk1)))
                (setq ptw2 (POLAR ptw1 ang1 (* 10 sk1)))
                (setq ptw3 (POLAR ptw2 ang1 (* 1.5 sk1)))
                (setq ptw2a(POLAR ptw2 (+ ang (dtr 180)) (* 3 sk1)))
                (setq ptw2b(POLAR ptw2 ang (* 3 sk1)))
            )
            (progn
                (setq ptw1 (POLAR pt1 ang (* 5.5 sk1)))
                (setq ptw2 (POLAR ptw1 ang1 (* 16 sk1)))
                (setq ptw3 (POLAR ptw2 ang1 (* 2.5 sk1)))
                (setq ptw2a(POLAR ptw2 (+ ang (dtr 180)) (* 5 sk1)))
                (setq ptw2b(POLAR ptw2 ang (* 5 sk1)))
            )
        )
    )
    (if (= future 1)
        (command "layer" "s" "1c" "")
        (command "layer" "s" "1h" "")
    )
    (if (= 1 hand-type)
        (command "pline" (POLAR pt1 ang1 flglen) "w" "0" "0" ptw2 (POLAR pt2 ang1 flglen) "")
        (command "pline" ptw2a "w" "0" "0" ptw1 ptw2b "")
    )
    (command "pline" ptw2  "w" "0" "0" ptw1 "")
    (if (= future 1)
        (command "layer" "s" "5c" "")
        (command "layer" "s" "2h" "")
    )
    (if (= c_item "GAT")
        (command "pline" ptw2  "w" p-wedth2 p-wedth2 ptw3 "")
    )
    (command "pline" ptw2a "w" p-wedth2 p-wedth2 ptw2b "")
)

(defun i-valve1()
    (command "layer" "s" "1c" "")
    (if (and (= con-val nil)(= sd "BW"))
        (progn
            (setq endpoint pt2)
            (command "line" (POLAR pt1 (+ ang (dtr 180)) (* 1.5 sk1)) pt2 "")
            (cond
                ((= future 1)
                    (command "insert" "c:/ghk/iso/isoweld" pt1 sk1 "" "")
                    (command "insert" "c:/ghk/iso/isoweld" pt2 sk1 "" "")
                )
                ((= future 0)
                    (command "layer" "s" "2h" "")
                    (command "circle" pt1 sk1)
                    (command "circle" pt2 sk1)
                )
            )
        )
        (progn
            ;(if (and (or (/= sd "FLG") (/= sd "WAFER")) (= valend-type 2) (= con-val nil))
            (if (or (= sd "BW") (and (= sd "SW") (= valend-type 2) (= con-val nil)))
                (setq endpoint pt2)
                (setq endpoint (POLAR pt2 ang (* 0.75 sk1)))
            )
            (command "line" (POLAR pt1 (+ ang (dtr 180)) (* 1.5 sk1)) (POLAR pt2 ang (* 0.75 sk1)) "")
        )
    )
    (setq endang ang)
    (setq endang1 ang1)
    (setq con-val nil)
)
(defun i-valve2()
    (if (or (and (= con-val nil) (= sd "SW")) (and (= con-val nil)(= sd "SCR'D")))
        (progn
            (command "pline" (POLAR pt1 ang1 flglen) "w" "0" "0" (POLAR (POLAR pt1 (+ ang (dtr 180)) (* 1 sk1)) ang1 flglen) "")
            (command "pline" (POLAR pt1 (+ ang1 (dtr 180)) flglen) "w" "0" "0" (POLAR (POLAR pt1 (+ ang (dtr 180)) (* 1 sk1)) (+ ang1 (dtr 180)) flglen) "")
            (command "pline" (POLAR pt2 ang1 flglen) "w" "0" "0" (POLAR (POLAR pt2 ang (* 1 sk1)) ang1 flglen) "")
            (command "pline" (POLAR pt2 (+ ang1 (dtr 180)) flglen) "w" "0" "0" (POLAR (POLAR pt2 ang (* 1 sk1)) (+ ang1 (dtr 180)) flglen) "")
        )
    )
)
