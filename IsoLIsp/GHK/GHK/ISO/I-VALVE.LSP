(defun i-ball1()
    (if (= sd "FLG")(if (= job_direc 2)(progn (i-gas)(i-blt))))
    (setq c_item "BAL")
    (setq c_itemno "120")
    (sc1)
    (i-valve)
    (if (= sd "BW")
        (progn
            (setq pt1a (POLAR pt1 ang1 piplen))
            (setq pt1b (POLAR pt1 (+ ang1 (dtr 180)) piplen))
            (setq pt1c (POLAR pt1a ang piplen))
            (setq pt1d (POLAR pt1b ang piplen))
            (setq pt2a (POLAR (POLAR pt2 ang piplen) ang1 piplen))
            (setq pt2b (POLAR (POLAR pt2 ang piplen) (+ ang1 (dtr 180)) piplen))
            (setq pt2c (POLAR pt2a ang piplen))
            (setq pt2d (POLAR pt2b ang piplen))
            (setq pt1  (POLAR pt1 ang piplen))
            (setq pt2  (POLAR pt2 ang piplen))
            (command "line" pt1c pt1a pt1b pt1d "")
            (command "line" pt2a pt2c pt2d pt2b "")
        )
    )
    (command "pline" (POLAR pt1 ang1 flglen) "w" "0" "0"
             (POLAR pt1 (+ ang1 (dtr 180)) flglen)
             (POLAR pt2 ang1 flglen)
             (POLAR pt2 (+ ang1 (dtr 180)) flglen) "c"
    )
;    (if (or (and (= con-val nil) (= sd "SW")) (and (= con-val nil)(= sd "SCR'D")))
;    (if (<= ghk endtype)
        (if (< ghk 49)
        (progn
            (if (= valend-type 1)
                (i-valve2)
            )
            (setq ptw1 (POLAR pt1 ang (* 4 sk1)))
        )
        (progn
            (setq ptw1 (POLAR pt1 ang (* 5.5 sk1)))
            (setq ptw2 (POLAR ptw1 ang1 (* flglen 2)))
            (setq ptw3 (POLAR ptw2 ang flglen))
            (command "pline" ptw1 "w" "0" "0" ptw2 ptw3 "")
        )
    )
    (ratchan)
    (if (and (= future 1)(= con-val nil))
        (if (/= dwgtype "D")(bmlist (POLAR pt1 ang (/ (distance pt1 pt2) 2))))
    )
    (command "layer" "s" "1c" "")
    (if (< ghk 49)
        (command "circle" ptw1 (* 1 sk1))
        (command "circle" ptw1 (* 2 sk1))
    )
    (if (= sd "BW")
        (cond
            ((= future 1)
                (command "insert" "c:/ghk/iso/isoweld" (POLAR pt1 (+ ang (dtr 180)) piplen) sk1 "" "")
                (command "insert" "c:/ghk/iso/isoweld" (POLAR pt2 ang piplen) sk1 "" "")
            )
            ((= future 0)
                (command "layer" "s" "2h" "")
                (command "circle" (POLAR pt1 (+ ang (dtr 180)) piplen) sk1)
                (command "circle" (POLAR pt2 ang piplen) sk1)
            )
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" (POLAR pt1 (+ ang (dtr 180)) (* 1.5 sk1)) (POLAR pt2 ang (* 1.5 sk1)) "")
    (if (= sd "BW")
        (setq endpoint (POLAR pt2 ang piplen))
        (setq endpoint (POLAR pt2 ang (* 0.75 sk1)))
    )
    (setq endang ang)
)

