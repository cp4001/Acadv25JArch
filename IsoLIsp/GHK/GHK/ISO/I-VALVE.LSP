(defun i-gate(/ flglen piplen pt1 pt2 pt1a pt1b pt1c pt1d pt2a pt2b
                pt2c pt2d ang ang1 ptw1)
    (setiso1)
    (setq c_item "GAT")
    (setq c_itemno "090")
    (sc1)
    (if (= con-val 1)(progn (setq sd "FLG")(setq sd-1 sd)))
    (set-selec i-gate1)
    (setiso2)
    (setq old_sd sd)
    (if (/= ventdr 1)(if (or (= sd "SW") (= sd "SCR'D"))(val-acc1)(if (=  sd "BW")(val-acc2)(val-acc))))
    (prin1)
)
(defun i-gate1()
    (if (= sd "FLG")(if (= job_direc 2)(progn (i-gas)(i-blt))))
    (setq c_item "GAT")
    (setq c_itemno "090")
    (sc1)
    (i-valve)
    (command "pline" (POLAR pt1 ang1 flglen) "w" "0" "0"
             (POLAR pt1 (+ ang1 (dtr 180)) flglen)
             (POLAR pt2 ang1 flglen)
             (POLAR pt2 (+ ang1 (dtr 180)) flglen) "c"
    )
    (if (= valend-type 1)
        (i-valve2)
    )
    (if (= ventdr 2)
        (if (/= sd "SCR'D")
            (progn
                (disc-cha sd "SW x SCR'D")
                (setq sd "SW x SCR'D")
                (setq c_item "GATD")
            )
        )
    )
    (ratchan)
    (if (and (= future 1)(= con-val nil))
        (if (/= dwgtype "D")(bmlist (POLAR pt1 ang (/ (distance pt1 pt2) 2))))
    )
    (i-while)
    (i-valve1)
)

