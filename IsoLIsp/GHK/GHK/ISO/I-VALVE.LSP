(defun i-but1()
    (if (= job_direc 2)(progn (if (or (= sd "FLG") (= sd "WAFER"))(i-gas))(if (= sd "FLG")(i-blt))))
    (setq c_item "BUT")
    (setq c_itemno "130")
    (sc1)
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF VALVE : "))
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setvar "osmode" 0)
            (setq ang (GETANGLE pt1 "\nPICK 2nd VALVE DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (if (< ghk 49)
        (setq flglen (* 3 sk1))
        (setq flglen (* 5 sk1))
    )
    (if (= sd "BW")
        (setq pt1 pt1)
        (setq pt1 (POLAR pt1 ang (* 0.75 sk1)))
    )
    (setq pt2 (POLAR pt1 ang flglen))
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK VALVE DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK VALVE DIRECTION: "))
    )
    (if (= future 1)
        (command "layer" "s" "2c" "")
        (command "layer" "s" "2h" "")
    )
    (command "pline" (POLAR pt2 ang1 flglen) "w" "0" "0"
                     (POLAR pt1 ang1 flglen)
                     (POLAR pt1 (+ ang1 (dtr 180)) flglen)
                     (POLAR pt2 ang1 flglen)
                     (POLAR pt2 (+ ang1 (dtr 180)) flglen)
                     (POLAR pt1 (+ ang1 (dtr 180)) flglen) ""
    )
    (command "donut" "0" (* 1.5 sk1) (POLAR pt1 ang (/ flglen 2.0)) "")
    (ratchan)
    (if (and (= future 1)(= con-val nil))
        (if (/= dwgtype "D")(bmlist (POLAR pt1 ang (/ (distance pt1 pt2) 2))))
    )
    (i-valve1)
)


(defun i-safety(/ flglen pt1 pt2 pt3 ang ang1 pt1a pt1b pt3a pt3b pt4
                  pt4a pt4b pt5 pt5a pt5b pt6 pt6a pt6b pt7)
    (setiso1)
    (if (= job_direc 2)(progn (i-gas)(i-blt)))
    (setq c_itemno "090")
    (sc1)
    (setq tee-type 4)
    (ch-size ghk)
    (if (not i-rtee)(load"c:/ghk/iso/i-tee"))
    (i-rtee)
    (setq ghk br-size)
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF VALVE : "))
            (setvar "osmode" 0)
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setq ang (GETANGLE pt1 "\nPICK 2nd VALVE DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= ang nil)(setq ang endang))
    (IF (= pt1 nil)(setq pt1 endpoint))
    (if (< ghk 49)
        (progn
           (setq flglen (* 3 sk1))
           (setq pt1 (POLAR pt1 ang 0))
           (setq pt2 (POLAR pt1 ang (* 8 sk1)))
        )
        (progn
           (setq flglen (* 5 sk1))
           (setq pt1 (POLAR pt1 ang (* 0.75 sk1)))
           (setq pt2 (POLAR pt1 ang (* 11 sk1)))
        )
    )
    (initget 1)
    (setq ang1 (GETANGLE pt2 "\nPICK 3rd VALVE DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK VALVE DIRECTION: "))
    )
    (if (< ghk 49)
        (setq pt3 (POLAR pt2 ang1 (* 8 sk1)))
        (setq pt3 (POLAR pt2 ang1 (* 11 sk1)))
    )
    (setq pt1a (POLAR pt1 (+ ang1 (dtr 180)) flglen))
    (setq pt1b (POLAR pt1 ang1 flglen))
    (setq pt3a (POLAR pt3 (+ ang (dtr 180)) flglen))
    (setq pt3b (POLAR pt3 ang flglen))
    (setq pt4  (POLAR pt2 ang (* flglen 1.5)))
    (setq pt4a (POLAR pt4 (+ ang1 (dtr 180)) (/ flglen 1.5)))
    (setq pt4b (POLAR pt4 ang1 (/ flglen 1.5)))
    (setq pt5  (POLAR pt4 ang (/ flglen 1.5)))
    (setq pt5a (POLAR pt5 (+ ang1 (dtr 180)) (/ flglen 1.5)))
    (setq pt5b (POLAR pt5 ang1 (/ flglen 1.5)))
    (setq pt6  (POLAR pt5 ang (/ flglen 1.5)))
    (setq pt6a (POLAR pt6 (+ ang1 (dtr 180)) (/ flglen 1.5)))
    (setq pt6b (POLAR pt6 ang1 (/ flglen 1.5)))
    (setq pt7  (POLAR pt6 ang (/ flglen 1.5)))
    (if (= future 1)
        (command "layer" "s" "2c" "")
        (command "layer" "s" "2h" "")
    )
    (command "pline" pt1a "w" "0" "0" pt2 pt3b pt3a pt2 pt1b pt1a "")
    (command "line" pt2 pt7 "" "line" pt4a pt4b "" "line" pt5a pt5b "" "line" pt6a pt6b "")
    (command "layer" "s" "1c" "")
    (command "line" (POLAR pt1 (+ ang (dtr 180)) (* 0.75 sk1)) pt2 (POLAR pt3 ang1 (* 0.75 sk1)) "")
    (if (< ghk 49)
        (setq endpoint pt3)
        (setq endpoint (POLAR pt3 ang1 (* 0.75 sk1)))
    )
    (setq endang ang1)
    (setiso2)
    (setq old_sd sd)
    (IF (not pi-tag)(load"c:/ghk/iso/fitting"))(pi-tag)
    (val-acc)
    (prin1)
)

