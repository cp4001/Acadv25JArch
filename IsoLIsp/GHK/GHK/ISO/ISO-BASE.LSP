(defun sc1(/ bmlst1 bmlst2 bmlst1- i_sock 1_weld i_large bmlst2- bmlst20-
             bmlst21- )
    (sslist2 c_class)
    (setq c_disc "")
    (setq bmlst1- (nth (atoi (substr c_itemno 1 2)) bmlst1))
    (setq i_sock (nth 0 bmlst1-))
    (setq i_weld (nth 1 bmlst1-))
    (setq i_large (nth 2 bmlst1-))
    (setq bmlst2- (nth (atoi (substr c_itemno 1 2)) bmlst2))
    (setq bmlst20- (nth 0 bmlst2-))
    (setq bmlst21- (nth 1 bmlst2-))
    (setq endtype (atoi(nth 0 bmlst1-)))
    (if (and (> ghk 0) (<= ghk (atof i_sock)))
        (setq c_disc (nth 0 bmlst20-))
        (if (and (>= ghk (atof i_sock)) (<= ghk (atof i_weld)))
            (setq c_disc (nth 1 bmlst20-))
            (if (and (>= ghk (atof i_weld)) (<= ghk (atof i_large)))
                (setq c_disc (nth 2 bmlst20-))
            )
        )
    )
    (if (and (> ghk 0) (<= ghk (atof i_sock)))
        (setq sd (nth 0 bmlst21-))
        (if (and (>= ghk (atof i_sock)) (<= ghk (atof i_weld)))
            (setq sd (nth 1 bmlst21-))
            (if (and (>= ghk (atof i_weld)) (<= ghk (atof i_large)))
                (setq sd (nth 2 bmlst21-))
            )
        )
    )
)

(defun ftof(/ sizenum1 chsize1 ftofnum fitlen ell90 ell90q ell90s ell90sq
              ell45 ell45q lentee lenteeq lenred lenredq lst1 lst2 pipe-size
              lst2-)
 (setq dcl_id (load_dialog "c:/ghk/iso/ssspec.dcl"))
  (if (not (new_dialog "ftof" dcl_id))
      (exit)
  )
 (sslist1 "fitting")
 (setq sizenum1 sizenum)
 (setq chsize1 chsize)
 (ch-size (atoi t-sizeno))
 (setq ftofnum (rtos (- (atoi sizenum) 7) 2 0))
 (setq pipe-size (nth (atoi ftofnum) lst1))
 (setq lst2- (nth (atoi ftofnum) lst2))
 (setq fitlen n-len)
 (setq ell90(nth 0 lst2-))
 (setq ell90q "0")
 (setq ell90s(nth 1 lst2-))
 (setq ell90sq "0")
 (setq ell45(nth 2 lst2-))
 (setq ell45q "0")
 (setq lentee(nth 3 lst2-))
 (setq lenteeq "0")
 (setq lenred(nth 4 lst2-))
 (setq lenredq "0")
 (action_tile "zpipe-size" "(setq pipe-size $value)")
 (action_tile "mainsize"   "(ftof_1 (setq ftofnum $value))")
 (action_tile "zfitlen"    "(setq fitlen $value)")
 (action_tile "zell90"     "(setq ell90 $value)")
 (action_tile "zell90q"    "(setq ell90q $value)")
 (action_tile "zell90s"    "(setq ell90s $value)")
 (action_tile "zell90sq"   "(setq ell90sq $value)")
 (action_tile "zell45"     "(setq ell45 $value)")
 (action_tile "zell45q"    "(setq ell45q $value)")
 (action_tile "zlentee"    "(setq lentee $value)")
 (action_tile "zlenteeq"   "(setq lenteeq $value)")
 (action_tile "zlenred"    "(setq lenred $value)")
 (action_tile "zlenredq"   "(setq lenredq $value)")
 (start_list "mainsize")
 (mapcar 'add_list lst1)
 (end_list)
 (set_tile "mainsize" ftofnum)
 (set_tile "zpipe-size" pipe-size)
 (set_tile "zfitlen"  fitlen)
 (set_tile "zell90"   ell90)
 (set_tile "zell90q"  ell90q)
