(defun ftof_2()
    (setq n-len(rtos (- (atoi fitlen) (+
                    (* (atoi ell90)  (atoi ell90q))
                    (* (atoi ell90s) (atoi ell90sq))
                    (* (atoi ell45)  (atoi ell45q))
                    (* (atoi lentee) (atoi lenteeq))
                    (* (atoi lenred) (atoi lenredq))
                )) 2 0)
    )
)

(defun ssbolt3(/ boltlen len_last add_len len-fst)
    (setq b-len(rtos (+ (atof b-len) (atof lenadd)) 2 0))
    (setq boltlen(strlen b-len))
    (setq len_last(atof (substr b-len boltlen)))
    (setq add_len(- 10 len_last))
    (if (<= 8 add_len)
        (setq b-len(rtos (- (atof b-len) len_last) 2 0))
        (if (<= 3 add_len)
            (progn
                (setq len-fst(substr b-len 1 (- boltlen 1)))
                (setq b-len(strcat len-fst "5"))
            )
            (setq b-len(rtos (+ (atof b-len) add_len) 2 0))
        )
    )
)

