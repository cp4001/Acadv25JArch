;Set iso no.1
(defun setiso1()
    (setq olderr *error* *error* ghkerr)
    (setvar "cmdecho" 0)
    (layer1)
    (graphscr)
    (if (= ghk nil)(setq ghk 150))
    (command "layer" "t" "*" "")
    (setq la (getvar "clayer"))
    (setq orth(getvar "orthomode"))
    (setq os(getvar "osmode"))
    (setq c_dwgname(getvar "dwgname"))
    (if (= (strcase (substr c_dwgname (- (strlen c_dwgname) 3))) ".DWG")
        (setq c_dwgname(substr c_dwgname 1 (- (strlen c_dwgname) 4)))
    )
    (if (> (strlen (getvar "dwgprefix")) (strlen (getvar "dwgname")))
        (setq c_dwgname c_dwgname
          file_no (strcat (getvar "dwgprefix") c_dwgname)
        )
        (setq c_dwgname(substr (getvar "dwgname") (+ (strlen (getvar "dwgprefix")) 1))
	      file_no (getvar "dwgprefix")
        )
    )
    (if (= c_dwgname "")
        (setq c_dwgname "UNNAME")
    )
    (if (or (= c_class "None") (= c_class " "))
        (progn
            (ssspec)
            (resetiso)
        )
    )
)

