(defun resetiso()
    (setvar "modemacro" (strcat "Layer:$(substr,$(getvar,clayer),1,8)"
                            " Spec : " (strcat "[" c_class "] ")
                            (if (= ghk nil) " Unselect Size" (strcat " " (rtos ghk 2 0) "A "))
                            " Rat:"(if (= rat "A") " 150#" (if (= rat "B") " 300#" (if (= rat "C") " 600#" (if (= rat "D") " 900#" (if (= rat "E") " 1500#")))))
                            " Flg:"(if (= sd "SO") " SLIP ON" (if (= sd "LA") " LAP JOINT" (if (= sd "WN") " WELD NECK" (if (= sd "SW") " SOCK WELD" (if (= sd "SCR'D") " SCR'D" sd)))))
                            "  " (if (= future 1) " CONT. " (if (= future 0) " HIDDEN "))
                        )
    )
    (isobase1)
)

;Data file read
(defun sslist1 (file / fn n-line if1)
 (setq lst1 nil lst2 nil)
 (setq fn(open (strcat "c:/ghk/iso/" file".dat") "r"))
 (setq msg(read-line fn))
 (while (setq n-line(read-line fn))
        (setq if1(substr n-line 1 1))
        (cond ((= if1 "*")
               (setq lst1(cons (substr n-line 2) lst1))
              )
              ((= if1 "(")
               (setq lst2(cons (read n-line) lst2))
              )
        )
 )
 (setq lst1(reverse lst1) lst2(reverse lst2))
 (close fn)
)

;Data file read
(defun sslist2 (file / fn n-line if1)
 (setq bmlst1 nil bmlst2 nil)
 (setq fn(open (strcat "c:/ghk/iso/" file".spc") "r"))
 (setq msg(read-line fn))
 (while (setq n-line(read-line fn))
        (setq if1(substr n-line 1 1))
        (cond ((= if1 "*")
               (setq bmlst1(cons (read (substr n-line 2)) bmlst1))
              )
              ((= if1 "(")
               (setq bmlst2(cons (read n-line) bmlst2))
              )
        )
 )
 (setq bmlst1(reverse bmlst1) bmlst2(reverse bmlst2))
)

(defun isobase(/ aaa a b c d e f g h a1 b1 c1 d1 e1 f1 g1 h1)
    (setvar "cmdecho" 0)
    (setvar "attdia" 0)
    (setq aaa(ssget "X" (list (cons 0 "INSERT")(cons 2 "ISOBASE"))))
    (if (/= aaa nil)
        (progn
            (setq a(ssname aaa 0))
            (setq b(entnext a))
            (setq c(entnext b))
            (setq d(entnext c))
            (setq e(entnext d))
            (setq f(entnext e))
            (setq g(entnext f))
            (setq h(entnext g))
            (setq i(entnext h))
            (setq a1 (entget a))
            (setq b1 (entget b));;DWGNAME
            (setq c1 (entget c));;CLASS
            (setq d1 (entget d));;RATING
            (setq e1 (entget e));;SIZE
            (setq f1 (entget f));;END TYPE
            (setq g1 (entget g));;CONNECTION TYPE
            (setq h1 (entget h));;HAND WHILE
            (setq i1 (entget i));;SIZE TYPE
            (setq c_class   (cdr (assoc 1 c1)))
            (setq rat       (cdr (assoc 1 d1)))
            (setq ghk       (atoi (cdr (assoc 1 e1))))
            (setq sd        (cdr (assoc 1 f1)))
            (setq con-type  (atoi (cdr (assoc 1 g1))))
            (setq hand-type (atoi (cdr (assoc 1 h1))))
            (setq size-type (atoi (cdr (assoc 1 i1))))
            (resetiso)
        )
    )
)

(defun isobase1(/ aaa a b c d e f g h a1 b1 c1 d1 e1 f1 g1 h1 ghk1
                  con-type1 hand-type1 r-dwgname d-1 b-1 r-spec r-ghk
                  r-rat r-sd r-con-type r-hand-type r-size-type)
    (setvar "cmdecho" 0)
    (setvar "attdia" 0)
    (setq aaa(ssget "X" (list (cons 0 "INSERT")(cons 2 "ISOBASE"))))
    (setq a(ssname aaa 0))
    (setq b(entnext a))
    (setq c(entnext b))
    (setq d(entnext c))
    (setq e(entnext d))
    (setq f(entnext e))
    (setq g(entnext f))
    (setq h(entnext g))
    (setq i(entnext h))
    (setq a1 (entget a))
    (setq b1 (entget b));;DWGNAME
    (setq c1 (entget c));;CLASS
    (setq d1 (entget d));;RATING
    (setq e1 (entget e));;SIZE
    (setq f1 (entget f));;END TYPE
    (setq g1 (entget g));;CONNECTION TYPE
    (setq h1 (entget h));;HAND WHILE
    (setq i1 (entget i));;SIZE TYPE
    (setq c_dwgname(getvar "dwgname"))
    (if (= (strcase (substr c_dwgname (- (strlen c_dwgname) 3))) ".DWG")
        (setq c_dwgname(substr c_dwgname 1 (- (strlen c_dwgname) 4)))
    )
    (if (> (strlen (getvar "dwgprefix")) (strlen (getvar "dwgname")))
        (setq c_dwgname c_dwgname
          file_no (strcat (getvar "dwgprefix") c_dwgname)
        )
        (setq c_dwgname(substr (getvar "dwgname") (+ (strlen (getvar "dwgprefix")) 1))
	      file_no (getvar "dwgprefix")
        )
    )
    (setq ghk1 (rtos ghk 2 0))
    (setq con-type1  (rtos con-type 2 0))
    (setq hand-type1 (rtos hand-type 2 0))
    (setq size-type1 (rtos size-type 2 0))
    (setq r-dwgname(assoc 1 b1))
    (setq d-1(cons (car r-dwgname) c_dwgname))
    (setq b-1 (subst d-1 r-dwgname b1))
    (entmod b-1)
    (setq r-spec(assoc 1 c1))
    (setq d-1(cons (car r-spec) c_class))
    (setq b-1 (subst d-1 r-spec c1))
    (entmod b-1)
    (setq r-rat(assoc 1 d1))
    (setq d-1(cons (car r-rat) rat))
    (setq b-1 (subst d-1 r-rat d1))
    (entmod b-1)
    (setq r-ghk(assoc 1 e1))
    (setq d-1(cons (car r-ghk) ghk1))
    (setq b-1 (subst d-1 r-ghk e1))
    (entmod b-1)
    (setq r-sd(assoc 1 f1))
    (setq d-1(cons (car r-sd) sd))
    (setq b-1 (subst d-1 r-sd f1))
    (entmod b-1)
    (setq r-con-type(assoc 1 g1))
    (setq d-1(cons (car r-con-type) con-type1))
    (setq b-1 (subst d-1 r-con-type g1))
    (entmod b-1)
    (setq r-hand-type(assoc 1 h1))
    (setq d-1(cons (car r-hand-type) hand-type1))
    (setq b-1 (subst d-1 r-hand-type h1))
    (entmod b-1)
    (setq r-size-type(assoc 1 i1))
    (setq d-1(cons (car r-size-type) size-type1))
    (setq b-1 (subst d-1 r-size-type i1))
    (entmod b-1)
    (setvar "attdia" 1)
)

