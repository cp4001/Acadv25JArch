(defun filedw(/ ang1 tagd p2 p1 ang p3 p4 p5 p6 p7 p8)
    (setiso1)
    (setq t_style(getvar "textstyle"))
    (setvar "textstyle" "standard")
    (setq ang1 (rtd 0))
    (setvar "osmode" 0)
    (setvar "orthomode" 0)
    (setq tagd 5.5)
    (if (= tagn nil)(setq tagn "001"))
    (setq filedwend 1)
    (while filedwend
        (prompt "\n ****---- TAG NUMBER ----****")
        (setq p2 (getpoint "\nSelect point :"))
        (if (= p2 nil)
            (setq filedwend nil)
            (progn
                (setq p1 (getpoint P2 "\nTag center point :"))
                (setq ang (angle p1 p2))
                (setq p3 (polar p1 ang (* tagd s)))
                (setq p4 (polar p1 (dtr 90) (* 0.5 s)))
                (setq p5 (polar p4 (dtr 90) (* 2.5 s)))
                (setq p6 (polar p1 (dtr 0)   (* tagd s)))
                (setq p7 (polar p1 (dtr 180) (* tagd s)))
                (setq p8 (polar p1 (dtr 270) (* tagd s)))
                (command "layer" "s" "2c" "")
                (command "circle" p1 (* tagd s))
                (command "line"  p2 p3 "")
                (command "line"  p6 p7 "")
                (command "line"  p1 p8 "")
                (command "text" "j" "c" p5 (* 2 s) "0" "SW")
                (command "text" "j" "c" p4 (* 2 s) "0" tagn)
                (setq tagn(rtos (+ (atoi tagn) 1) 2 1))
                (cond
                    ((= (strlen tagn) 1)
                        (setq tagn(strcat "00" tagn))
                    )
                    ((= (strlen tagn) 2)
                        (setq tagn(strcat "0" tagn))
                    )
                )
            )
        )
    )
    (setvar "textstyle" t_style)
    (setiso2)
)

