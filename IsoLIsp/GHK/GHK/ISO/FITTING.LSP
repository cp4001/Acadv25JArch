(defun i-nip(/ sd pt1 pt2 ang nipple niplen niptxt1 niptxt2 niptxt3 niptxt4)
    (setiso1)
    (setq c_itemno "000")
    (sc1)
    (if (= ventdr 1)
        (if (/= sd "SCR'D")
            (progn
                (setq niptxt1 "NPT")
                (setq niptxt2 "1")
                (setq niptxt3 "PE x TE")
                (setq niptxt4 "75mm")
;                (setq c_item (strcat niptxt1 niptxt2))
                (setq c_item niptxt1)
                (disc-cha sd niptxt3)
            )
            (progn
                (setq niptxt1 "NTE")
                (setq niptxt2 "1")
                (setq niptxt3 "TBE")
                (setq niptxt4 "75mm")
;                (setq c_item (strcat niptxt1 niptxt2))
                (setq c_item niptxt1)
                (disc-cha sd niptxt3)
            )
        )
        (i-nip2)
    )
    (if (< ghk endtype)
        (set-selec i-nip1)
    )
    (setiso2)
    (if (/= ventdr 1)(if (or (= sd "PE") (= sd "TE"))(val-acc3)(if (= sd "BE")(val-acc2)(val-acc))))
    (prin1)
)

(defun i-nip1()
    (if (= job_direc 1)
        (progn
            (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF NIPPLE : "))
            (setvar "osmode" 0)
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setq ang (GETANGLE pt1 "\nPICK NIPPLE DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (setq pt2 (POLAR pt1 ang (* 4 sk1)))
    (cond
        ((= future 1)
            (command "layer" "s" "5c" "")
            (command "pline" pt1 "w" (if (= future 0) "0" p-wedth3) (if (= future 0) "0" p-wedth3) pt2 "")
            (setq c_itemno (strcat c_itemno "1"))
            (if (/= dwgtype "D")
                (if (= size-type 1)
                    (bmlist1 (POLAR pt1 ang (/ (distance pt1 pt2) 2)) (strcat (ch-size ghk) (chr 34) "x" niptxt4))
                    (bmlist1 (POLAR pt1 ang (/ (distance pt1 pt2) 2)) (strcat (rtos ghk 2 0) "Ax" niptxt4))
                )
            )
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
            (command "line" pt1 pt2 "")
        )
    )
    (setq endpoint pt2)
    (setq endang (angle pt1 pt2))
)

(defun i-nip2()
    (setq dcl_id (load_dialog "c:/ghk/iso/valist.dcl"))
    (if (not old_point)(setq old_point '(640 480)))
    (if (not (new_dialog "nipple" dcl_id "" old_point))
        (exit)
    )
    (setq nipple 2 niplen 2)
    (set_tile "znpt" "1")
    (set_tile "z100" "1")
    (action_tile "accept" "(progn (setq x $x y $y) (setq old_point (done_dialog 1)))")
    (action_tile "znpe" "(setq nipple 1)")
    (action_tile "znpt" "(setq nipple 2)")
    (action_tile "znte" "(setq nipple 3)")
    (action_tile "z75"  "(setq niplen 1)")
    (action_tile "z100" "(setq niplen 2)")
    (action_tile "z150" "(setq niplen 3)")
    (action_tile "zsd"  "(setq sd $value)")
    (set_tile "zsd" sd)
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (if (= ok 1)
        (progn
            (cond
                ((= nipple 1)
                    (setq niptxt1 "NPE")
                    (setq niptxt3 "PBE")
                )
                ((= nipple 2)
                    (setq niptxt1 "NPT")
                    (setq niptxt3 "PE x TE")
                )
                ((= nipple 3)
                    (setq niptxt1 "NTE")
                    (setq niptxt3 "TBE")
                )
            )
            (cond
                ((= niplen 1)
                    (setq niptxt2 "1")
                    (setq niptxt4 "75mm")
                )
                ((= niplen 2)
                    (setq niptxt2 "2")
                    (setq niptxt4 "100mm")
                )
                ((= niplen 3)
                    (setq niptxt2 "3")
                    (setq niptxt4 "150mm")
                )
            )
:            (setq c_item (strcat niptxt1 niptxt2))
            (setq c_item niptxt1)
            (disc-cha sd niptxt3)
        )
    )
)

