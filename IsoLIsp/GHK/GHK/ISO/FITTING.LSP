(defun ftt-base(fttbase1 /)
    (if (= job_direc 1)
        (progn
            (SETQ pt1 (GETPOINT (strcat "\nPICK 1ST POINT OF " fttbase1 " : ")))
            (setvar "osmode" 0)
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setq ang (GETANGLE pt1 (strcat "\nPICK " fttbase1 " CENTER DIRECTION: ")))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (setq pt0 (POLAR pt1 ang (* 2 sk1)))
    (initget 1)
    (if (= ventdr 1)
        (setq ang1 endang1)
        (progn
            (setq ang1 (GETANGLE pt0 (strcat "\nPICK 2nd " fttbase1 " DIRECTION: ")))
            (IF (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
                (setq ang1 (GETANGLE pt0 (strcat "\nPICK 2nd " fttbase1 "DIRECTION: ")))
            )
        )
    )
)

(defun i-wol2(/ dcl_id mainum1 s-num lst1 lst2 lst2- lst20- lst30-)
    (setq dcl_id (load_dialog "c:/ghk/iso/iredtee.dcl"))
    (if (not (new_dialog "iweldolet" dcl_id))
        (exit)
    )
    (sslist1 "wol")
    (setq mainum1 "0")
    (setq s-num (- (atoi sizenum) 6))
    (setq lst2- (nth s-num lst2))
    (setq lst20- (nth 0 lst2-));brencht size mm
    (setq lst30- (nth 1 lst2-));brencht size inch
    (setq br-size1(atoi (nth 0 lst20-)))
    (setq br-size2(nth 0 lst30-))
    (action_tile "br_size"  "(wol_1 (setq mainum1 $value))")
    (start_list "br_size")
    (if (= size-type 1)
        (mapcar 'add_list lst30-)
        (mapcar 'add_list lst20-)
    )
    (end_list)
    (set_tile "br_size" "0")
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
)

(defun wol_1(data)
    (setq lst20- (nth 0 lst2-));brencht size mm
    (setq lst30- (nth 1 lst2-));brencht size inch
    (setq br-size1(atoi (nth (atoi data) lst20-)))
    (setq br-size2(nth (atoi data) lst30-))
)
