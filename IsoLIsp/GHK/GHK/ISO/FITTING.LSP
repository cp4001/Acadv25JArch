(defun pi-tag(/ ang1 p2 p1 ang p3 p4 p5 p6 p7)
    (setiso1)
    (setq t_style(getvar "textstyle"))
    (setvar "textstyle" "standard")
    (setq ang1 (rtd 0))
    (setvar "osmode" 0)
    (setvar "orthomode" 0)
    (prompt "\n ****---- TAG NUMBER ----****")
    (setq p2 (getpoint "\nSelect point :"))
    (setq p1 (getpoint P2 "\nTag center point :"))
    (setq ang (angle p1 p2))
    (setq p3 (polar p1 ang (* 5 s)))
    (setq p4 (polar p1 (+ ang1 1.5708) (* 1 s)))
    (setq p5 (polar p1 (+ ang1 -1.5708) (* 3 s)))
    (setq p6 (polar p5 ang1 (* 4 s)))
    (setq p7 (polar p5 (+ ang1 -3.14159) (* 4 s)))
    (command "layer" "s" "1C" "")
    (command "circle" p1 (* 5 s))
    (command "line"  p2 p3 "")
    (command "layer" "s" "2C" "")
    (command "text" "j" "c" p4 (* 2.2 s) "0" "PI")
    (command "text" "j" "c" p5 (* 2.2 s) "0" "313C")
    (setvar "textstyle" t_style)
    (setiso2)
)
