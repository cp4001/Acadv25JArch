(defun i-wol(/ sd pt1 pt0 pt2 ang ang1 pt1a pt1b pt3 pt3a pt3b pt4 pt4a
               pt4b ghk1 br-size1 br-size2)
    (setiso1)
    (ch-size ghk)
    (if (> ghk endtype)
        (progn
            (i-wol2)
            (setq ghk1 ghk)
            (setq ghk br-size1)
            (setq c_itemno "010")
            (sc1)
            (cond
                ((= sd "SCR'D")
                    (setq c_item "TOL")
                )
                ((= sd "SW")
                    (setq c_item "SOL")
                )
                ((= sd "BW")
                    (setq c_item "WOL")
                )
            )
            (setq ghk ghk1)
            (i-wol1)
        )
    )
    (setiso2)
    (val-acc1)
    (prin1)
)

(defun i-wol1()
    (if (= c_disc "")
        (prompt " IS NOT SPEC SIZE ")
        (progn
            (setvar "osmode" 512)
            (ftt-base c_item)
            (setq pt2 (POLAR pt0 ang (* 3 sk1)))
            (command "layer" "s" "5c" "")
            (setq pt1a (POLAR pt1  ang1 (* 1 sk1)))
            (setq pt1b (POLAR pt1  (+ ang1 (dtr 180)) (* 1 sk1)))
            (setq pt3  (POLAR pt1  ang (* 2 sk1)))
            (setq pt3a (POLAR pt3  ang1 (* 1.5 sk1)))
            (setq pt3b (POLAR pt3  (+ ang1 (dtr 180)) (* 1.5 sk1)))
            (setq pt4  (POLAR pt3  ang (* 1.5 sk1)))
            (setq pt4a (POLAR pt4  ang1 (* 1 sk1)))
            (setq pt4b (POLAR pt4  (+ ang1 (dtr 180)) (* 1 sk1)))
            (cond
                ((= future 1)
                    (setq c_itemno (strcat c_itemno "4"))
                    (if (/= dwgtype "D")
                        (if (= size-type 1)
                            (bmlist1 pt1b (strcat (ch-size ghk) (chr 34) "x" br-size2 (chr 34)))
                            (bmlist1 pt1b (strcat (rtos ghk 2 0) "Ax" (rtos br-size1 2 0) "A"))
                        )
                    )
                    (command "layer" "s" "5c" "")
                )
                ((= future 0)
                    (command "layer" "s" "2h" "")
                )
            )
            (command "pline" pt1a "w" (if (= future 0) "0" p-wedth1) (if (= future 0) "0" p-wedth1) pt3a pt4a pt4b pt3b pt1b "")
            (command "pline" pt3a "w" (if (= future 0) "0" p-wedth1) (if (= future 0) "0" p-wedth1) pt3b "")
            (command "layer" "s" "1c" "")
            (command "line" pt1 pt2 "")
            (setq endpoint pt2)
            (setq endang (angle pt0 pt2))
        )
    )
)

