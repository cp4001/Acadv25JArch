(defun i-cap1()
    (setvar "osmode" 1)
    (ftt-base "CAP")
    (if (<= ghk endtype)
        (setq caplen (* 3 sk1))
        (setq caplen (* 9 sk1))
    )
    (setq pt2 (POLAR pt1 ang (* caplen 0.666)))
    (setq pt1a (POLAR pt1  ang1 (/ caplen 2)))
    (setq pt1b (POLAR pt1a ang  (/ caplen 2)))
    (setq pt1c (POLAR pt1b (+ ang1 (dtr 180)) (/ caplen 2)))
    (setq pt1d (POLAR pt1c (+ ang1 (dtr 180)) (/ caplen 2)))
    (setq pt1e (POLAR pt1a (+ ang1 (dtr 180)) caplen))
    (cond
        ((= future 1)
            (setq c_itemno (strcat c_itemno "5"))
            (if (/= dwgtype "D")(bmlist pt1c))
            (command "layer" "s" "3c" "")
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
        )
    )
    (if (<= ghk endtype)
        (command "pline" pt1a "w" (if (= future 0) "0" p-wedth1) (if (= future 0) "0" p-wedth1) pt1b pt1d pt1e "")
        (progn
            (command "line" pt1a pt1e "")
            (command "arc" pt1a pt1c pt1e)
        )
    )
    (command "layer" "s" "1c" "")
    (command "line" pt1 pt2 "")
    (setq endpoint pt2)
)

