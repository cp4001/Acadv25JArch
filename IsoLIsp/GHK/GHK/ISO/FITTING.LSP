(defun i-blt(/ sd pt1 unitw1)
    (setiso1)
    (setvar "osmode" 0)
    (setq c_item "BLT")
    (setq c_itemno "080")
    (sc1)
    (if (or (= c_disc "") (= dwgtype "D"))
        (prompt "\nIS NOT SPEC SIZE ")
        (progn
            (if (= job_direc 1)
                (progn
                    (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF BOLT/NUT: "))
                    (terpri)
                    (setq unitw1(getstring "Do you want Bolt Q'TY <If Edit to Dialogue  [ D  or  Default ] = > :"))
                    (terpri)
                    (setq unitw1(strcase unitw1))
                )
            )
            (if (= old_sd "WAFER")
                (setq unitw1 "D")
            )
            (if (/= rat1 nil)
                (progn
                    (setq rat2 rat)
                    (setq rat rat1)
                )
            )
            (setq vallast nil)
            (if (= unitw1 "D")
                (ssbolt1)
                (ssbolt2)
            )
            (if (= unitw1 "D")(ssbolt3))
            (if (/= rat1 nil)
                (progn
                    (setq rat1 rat)
                    (setq rat rat2)
                )
            )
            (setq c_itemno "080")
            (IF (= endang nil) (setq endang (rtd 30)))
            (IF (= pt1 nil)
                (progn
                    (setq pt1 endpoint)
                    (bmlist4 (POLAR pt1 (- endang1 (dtr 180)) (* 3 sk1)) (strcat b-size "x" b-len) b-qty)
                )
                (bmlist4 pt1 (strcat b-size "x" b-len) b-qty)
            )
        )
    )
    (setiso2)
    (prin1)
)

