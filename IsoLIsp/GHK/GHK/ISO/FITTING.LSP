(defun i-sec(/ pt1 pt0 pt2 ang ang1 pt1a pt1b pt1c pt1d
                pt1e pt1f pt1g pt1h)
    (setiso1)
    (setvar "osmode" 1)
    (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF PIPE: "))
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (setq ang (GETANGLE pt1 "\nPICK PIPE CENTER DIRECTION: "))
    (IF (= ang nil)(setq ang endang))
    (setq pt0 (POLAR pt1 ang (* 2 sk1)))
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK 2nd PIPE DIRECTION: "))
    (setq pt2 (POLAR pt0 ang (* 1 sk1)))
    (command "layer" "s" "1c" "")
    (setq pt3  (POLAR pt1  ang1 (* 1.5 sk1)))
    (setq pt4  (POLAR pt3  ang1 (* 1.5 sk1)))
    (setq pt5  (POLAR pt1  (+ ang1 (dtr 180)) (* 1.5 sk1)))
    (setq pt6  (POLAR pt5  (+ ang1 (dtr 180)) (* 1.5 sk1)))
    (setq pt7  (POLAR pt5  (+ ang (dtr 180)) (* 0.5 sk1)))
    (setq pt8  (POLAR pt3  (+ ang (dtr 180)) (* 0.5 sk1)))
    (setq pt9  (POLAR pt3  ang  (* 0.5 sk1)))
    (command "arc" pt4 pt9 pt1)
    (command "arc" pt1 pt7 pt6)
    (command "arc" pt1 pt8 pt4)
    (setiso2)
    (prin1)
)

(defun i-flow(/ pt1 pt2 ang ang1 pt2a pt2b)
    (setiso1)
    (setvar "osmode" 512)
    (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF FLOW: "))
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (setq ang (GETANGLE pt1 "\nPICK FLOW CENTER DIRECTION: "))
    (IF (= ang nil)(setq ang endang))
    (setq pt2 (POLAR pt1 ang (* 9 sk1)))
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK 2nd FLOW DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK 2nd FLOW DIRECTION: "))
    )
    (command "layer" "s" "2c" "")
    (setq pt2a (POLAR pt2  ang1 (* 2.5 sk1)))
    (setq pt2b (POLAR pt2  (+ ang1 (dtr 180)) (* 2.5 sk1)))
    (cond
        ((= future 1)
            (command "solid" pt1 pt2a pt2b "" "")
        )
        ((= future 0)
            (command "layer" "s" "2h" "")
            (command "pline" pt1 "w" "0" "0" pt2a pt2b "c")
        )
    )
    (setiso2)
    (prin1)
)

(defun i-specb(/ pt1 pt2 ang ang1 pt3 pt3a pt3b)
