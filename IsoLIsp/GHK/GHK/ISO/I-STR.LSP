        ((or (and (= (rtos ang 2 4) (rtos (dtr 210) 2 4)) (= (rtos ang1 2 4) (rtos (dtr 270) 2 4))) (and (= (rtos ang 2 4) (rtos (dtr 270) 2 4)) (= (rtos ang1 2 4) (rtos (dtr 330) 2 4))))
            (setq ang-1 -11)
            (setq ang-2 -101)
        )
        ((or (and (= (rtos ang 2 4) (rtos (dtr 150) 2 4)) (= (rtos ang1 2 4) (rtos (dtr 270) 2 4))) (and (= (rtos ang 2 4) (rtos (dtr 270) 2 4)) (= (rtos ang1 2 4) (rtos (dtr 30) 2 4))))
            (setq ang-1 -70)
            (setq ang-2 -160)
        )
        (T
            (setq ang-1 22)
            (setq ang-2 63)
        )
    )
    (setq pt7c(POLAR pt7   (+ ang1 (dtr ang-1)) (* piplen 1.2)))
    (setq pt7d(POLAR pt7b  (+ ang1 (dtr ang-1)) (* piplen 1.2)))
