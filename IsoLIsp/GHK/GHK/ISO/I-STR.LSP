    (setq pt8c(POLAR pt8a  (+ ang1 (dtr ang-2)) (- flglen piplen (* 0.5 sk1))))
    (setq pt9 (POLAR pt8b  (+ ang1 (dtr ang-1)) (* flgwidth 2)))
    (setq pt9a(POLAR pt9   (+ ang1 (dtr ang-2)) (- (* flglen 2) (* 2 sk1))))
    (setq pt10(POLAR pt9   (+ ang1 (dtr ang-1)) (* flgwidth 2)))
    (setq pt10b(POLAR pt10 (+ ang1 (dtr ang-2)) (- flglen (* 1 sk1))))
    (setq pt10a(POLAR pt10b (+ ang1 (dtr ang-2)) (- flglen (* 1 sk1))))
