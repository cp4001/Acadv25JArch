        ((or (and (= (rtos ang 2 4) (rtos (dtr 30) 2 4)) (= (rtos ang1 2 4) (rtos (dtr 270) 2 4))) (and (= (rtos ang 2 4) (rtos (dtr 90) 2 4)) (= (rtos ang1 2 4) (rtos (dtr 330) 2 4))))
            (setq ang-1 75)
