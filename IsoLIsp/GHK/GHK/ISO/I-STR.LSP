(defun i-straner()
    (if (= job_direc 1)
        (progn
            (setvar "osmode" 1)
            (SETQ pt1 (GETPOINT "\nPICK 1ST POINT OF VALVE : "))
            (IF (= pt1 nil)(setq pt1 endpoint))
            (setvar "osmode" 0)
            (setq ang (GETANGLE pt1 "\nPICK 2nd VALVE DIRECTION: "))
        )
    )
    (setvar "osmode" 0)
    (IF (= pt1 nil)(setq pt1 endpoint))
    (IF (= ang nil)(setq ang endang))
    (if (or (= sd "SW") (= sd "SCR'D") (= sd "BW"))
        (setq pt1 pt1)
        (setq pt1 (POLAR pt1 ang (* 0.75 sk1)))
    )
    (if (< ghk 49)
        (progn
            (setq flglen (* 3 sk1))
            (setq piplen (* 1.5 sk1))
            (setq flgwidth (* 1.25 (* 0.2 sk1)))
        )
        (progn
            (setq flglen (* 5 sk1))
            (setq piplen (* 2.5 sk1))
            (setq flgwidth (* 1.75 (* 0.2 sk1)))
        )
    )
    (initget 1)
    (setq ang1 (GETANGLE pt1 "\nPICK VALVE DIRECTION: "))
    (if (and (<= ang1 (+ ang (dtr 10))) (>= ang1 (- ang (dtr 10))))
        (setq ang1 (GETANGLE pt1 "\nPICK VALVE DIRECTION: "))
    )
    (if (= future 1)
        (command "layer" "s" "2c" "")
        (command "layer" "s" "2h" "")
    )
)

(defun i-straner1()
    (if (= sd "BW")
