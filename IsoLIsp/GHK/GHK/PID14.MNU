***MENUGROUP=ACAD

//
//   Begin AutoCAD Digitizer Button Menus
//
***BUTTONS1
// Simple + button
// if a grip is hot bring up the Grips Cursor Menu (POP 17), else send a carriage return
$M=$(if,$(eq,$(substr,$(getvar,cmdnames),1,5),GRIP_),$P0=ACAD.GRIPS $P0=*);
$P0=SNAP $p0=*
^C^C
^B
^O
^G
^D
^E
^T

***BUTTONS2
// Shift + button
'ZOOM W
'ZOOM P
'PAN

***BUTTONS3
// Control + button

***BUTTONS4
// Control + shift + button

//
//   Begin System Pointing Device Menus
//
***AUX1
// Simple button
// if a grip is hot bring up the Grips Cursor Menu (POP 17), else send a carriage return
$M=$(if,$(eq,$(substr,$(getvar,cmdnames),1,5),GRIP_),$P0=ACAD.GRIPS $P0=*);
$P0=SNAP $p0=*
^C^C
^B
^O
^G
^D
^E
^T


***AUX2
// Shift + button
$P0=SNAP $p0=*
$P0=SNAP $p0=*

***AUX3
// Control + button
$P0=SNAP $p0=*

***AUX4
// Control + shift + button
$P0=SNAP $p0=*

