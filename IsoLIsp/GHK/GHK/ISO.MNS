                 [ 1/10]^C^Csetvar limmin 0,0;;ltscale 80;;limmax 4200,2970;;dimscale 10;;dimtxt 2.5;;dimasz 2.5;^C^Czoom a view s z 
                 [ 1/20]^C^Csetvar limmin 0,0;;ltscale 160;;limmax 8400,5940;;dimscale 20;;dimtxt 2.5;;dimasz 2.5;^C^Czoom a view s z 
                 [ Spec. ]^C^C^P(setq s(getreal "Do you want Scale :"))(setq maxy 420)(setq maxx 297)(dwg-scale) ^P
                 [->A4 scale]
                   [  1/1]^C^Csetvar limmin 0,0;;ltscale 80;;limmax 210,297;;dimscale 1;;dimtxt 2.5;;dimasz 2.5;^C^Czoom a view s z 
                   [<-<- Spec. ]^C^C^P(setq s(getreal "Do you want Scale :"))(setq maxy 297)(setq maxx 210)(dwg-scale) ^P

