ID_Qtour       [&Quick Tour]^P(if (startapp (findfile "qtour.exe")) (princ) (alert "Could not find or could not start Quick Tour.")) ^P
ID_Wnew        [&What's New]^P(if (startapp (findfile "wnew.exe")) (princ) (alert "Could not find or could not start What's New.")) ^P
