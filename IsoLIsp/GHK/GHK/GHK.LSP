(defun c:set1 ()
 (graphscr)
 (setvar "cmdecho" 0)
 (if (/= num1 nil)
     (if (> (atof num1) 6)
         (setq num1 "1")
     )
 )
)

(defun c:set2 ()
 (setvar "clayer" la)
 (setvar "osmode" os)
 (command "UNDO" "END")
)
(defun c:lst1 ()
 (command "point" '(0 0))
 (entdel (setq lst(entlast)))
 (setq add(ssadd))
)

(defun c:lst2 ()
 (setq lst(entlast))
 (setq add(ssadd))
 (setq add(ssadd lst add))
)

(defun ss-add ()
 (while (setq lst(entnext lst))
        (ssadd lst add)
 )
)

(defun layerch(a1 / a)
    (se1)
    (IF (/= a nil)
        (COMMAND "CHPROP" A "" "la" a1 "C" "BYLAYER" "LT" "BYLAYER" "" )
    )
)
(defun dim-scale()
    (setq dwgscale(getvar "dimscale"))
    (if (/= dwgscale s)(load"GHK"))
)
(defun ghkerr (jjj)
    (if (/= jjj "\nFunction cancelled")
        (princ (strcat "\nError : " jjj))
    )
    (command "layer" "s" la "")
    (setvar "osmode" os)
    (setvar "orthomode" orth)
)
(defun dwg-scale()
       (command "ltscale" s)
       (command "limits" "" (list (* s maxy)(* s maxx)))
       (command "dim" "dimscale" s "e")
       (command "zoom" "a")
       (setq menu-sel(strcase (getvar "menuname")))
       (cond
            ((= menu-sel "GHKBASE")
            (command "vslide" "ghkbase")
        )
        ((or (= menu-sel "C:\\GHK\\KIC") (= menu-sel "KIC"))
            (load"c:/ghk/lsp/planbase")
            (princ "\nPiping Plan Loading...................")
        )
        ((or (= menu-sel "C:\\GHK\\D-ISO") (= menu-sel "D-ISO"))
            (load"c:/ghk/iso/detail")
            (princ "\nPiping ISO Loading...................")
        )
        ((or (= menu-sel "C:\\GHK\\STRU") (= menu-sel "STRU"))
            (load"c:/ghk/stru/col-base")
            (princ "\nSteel Cad Shop Loading...................")
        )
        ((or (= menu-sel "C:\\GHK\\ISO") (= menu-sel "ISO"))
            (load"c:/ghk/iso/iso-base")
            (isobase)
            (princ "\nPiping ISO Loading...................")
        )
    )
)
(setq s (getvar "dimscale"))
(setq menu-sel(strcase (getvar "menuname")))
(cond
    ((or (= menu-sel "C:\\GHK\\KIC") (= menu-sel "KIC"))
