(defun s::startup ()
    (vmon)
    (setq sca 1)
    (command "cmdecho" "0")
    (load"c:/ghk/layer1")
    (load"c:/ghk/hotkey")
)
(defun tan (a)
  (/ (sin a) (cos a))
)
(defun dtr (a)
	(* pi (/ a 180.0))
)

(defun rtd (a)
	(/ (* a 180.0) pi)
)
(defun fix1 (a)
    (atoi (rtos a 2 0))
)
(defun se1()
  (setq olderr *error* *error* ghkerr)
  (command "cmdecho" "0")
  (command "UNDO" "GROUP")
  (setvar "cmdecho" 0)
  (SETQ A (SSGET))
  (layer1)
  (graphscr)
)
(defun se2()
    (setq olderr *error* *error* ghkerr)
    (command "cmdecho" "0")
    (dim-scale)
    (layer1)
    (graphscr)
    (setq la (getvar "clayer"))
    (setq orth(getvar "orthomode"))
    (setq os(getvar "osmode"))
    (command "orthomode" "1")
    (command "UNDO" "GROUP")
    (setvar "cmdecho" 0)
    (if (= ghk nil)
       (progn
        (setq ghk 50)
            (IF (not pdd50)
                (load"c:/ghk/lsp/design")
            )
        (pdd50)
       )
    )
    (RESETGHK)
    (initget 1)
)
