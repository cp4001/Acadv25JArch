;;;;;;;;;;;;;;;;;;
(defun tag5(/ p2 p1 ang p3 p4)
    (se4)
    (command "layer" "s" "2C" "")
    (command "osmode" 4)
    (setq p2 (getpoint "Select point :" ))
    (command "osmode" 0)
    (setq p1 (getpoint P2 "Tag center point :"))
    (setq ang(angle p2 p1))
    (setq p3 (polar p2 ang (* s 10)))
    (setq p4 (polar p3 (+ ang (dtr 180)) (* s 5)))
    (command "layer" "s" "1C" "")
    (command "circle" p3 "d" (* s 10))
    (command "line"  p2 p4 "")
    (command "layer" "s" "5C" "")
    (command "text" "j" "m" p3 (* s 4) "0" "A")
    (se6)
)
