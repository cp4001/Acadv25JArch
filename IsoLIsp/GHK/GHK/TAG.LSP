;;;;;;tag lisp
(defun tag1(/ d t p1 p2 ang p3)
    (se4)
    (setq d (* s 5))
    (setq t (* s 2.2))
    (command "orthomode" 0)
    (command "osmode" 0)
    (setq p2 (getpoint "Select point :"))(print)
    (setq p1 (getpoint p2 "Tag center point :"))(print)
    (setq ang (angle p1 p2))
    (setq p3 (polar p1 ang d))
    (command "layer" "s" "2c" "")
    (command "circle" p1 d )
    (command "dim" "lea" p2 p3 ^c "e")
    (command "text" "j" "m" p1 t "0" "1")
    (se6)
)
;;;;;;;;;;;;;;
(defun tag2(/ la orth os d t t1 t2 t3 ang1 p1 p2 ang p3 p4 p5 p6 p7)
    (se4)
    (command "orthomode" 0)
    (command "osmode" 0)
    (setq d (* s 5))
    (setq t (* s 2.2))
    (setq t1 (* s 1))
    (setq t2 (* s 3))
    (setq t3 (* s 4))
    (setq ang1 (rtd 0))
    (setq p2 (getpoint "Select point :"))(print)
    (setq p1 (getpoint P2 "Tag center point :"))(print)
    (setq ang (angle p1 p2))
    (setq p3 (polar p1 ang d))
    (setq p4 (polar p1 (+ ang1 1.5708) t1))
    (setq p5 (polar p1 (+ ang1 -1.5708) t2))
    (setq p6 (polar p5 ang1 t3))
    (setq p7 (polar p5 (+ ang1 -3.14159) t3))
    (command "layer" "s" "2C" "")
    (command "circle" p1 d )
    (command "line"  p2 p3 "")
    (command "text" "j" "c" p4 t "0" "PI")
    (command "text" "j" "C" p5 t "0" "2401")
    (se6)
)
