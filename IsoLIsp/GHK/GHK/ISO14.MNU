**pipemain 3
[**Main**]
[JUMP LINE]^c^c^p(IF (not linejump)(load"pipe"))(linejump) $s=x $s=linejump ^p
[ 90EL UP]^c^c^p(IF (not pipes)(load"pipe"))$s=x $s=pipes (if (= radu- "S")(menucmd "s=pipess")(menucmd "s=pipesl"))(pipes) ^p
[ 90EL DN]^c^c^p(IF (not peldn)(load"elbow"))$s=x $s=peldn (if (= radu- "S")(menucmd "s=peldns")(menucmd "s=peldnl"))(peldn) ^p
[ 90EL TN]^c^c^p(IF (not turn)(load"elbow"))$s=x $s=turn (if (= radu- "S")(menucmd "s=turns")(menucmd "s=turnl"))(turn) ^p
[45EL TU1]^c^c^p(IF (not pel45)(load"elbow"))(setq pel45-t 1)(pel45) $s=x $s=pel45 ^p
[45EL TU2]^c^c^p(IF (not pel45)(load"elbow"))(setq pel45-t 2)(pel45) $s=x $s=pel45 ^p
[45EL DN1]^c^c^p(IF (not p45el)(load"elbow"))(setq p45el-t 1)(p45el) $s=x $s=p45el ^p
[45EL DN2]^c^c^p(IF (not p45el)(load"elbow"))(setq p45el-t 2)(p45el) $s=x $s=p45el ^p
[ FLG UP ]^c^c^p(IF (not flgt)(load"flg"))$s=x $s=flgt (if (= radu- "S")(menucmd "s=flgts")(menucmd "s=flgtl"))(flgt) ^p
[ FLG DN ]^c^c^p(IF (not feldn)(load"flg"))$s=x $s=feldn (if (= radu- "S")(menucmd "s=feldns")(menucmd "s=feldnl"))(feldn) ^p
[STRAIGHT]
[ TEE FR ]^c^c^p(IF (not fst)(load"tee"))(fst) $s=x $s=fst ^p
[ TEE DN ]^c^c^p(IF (not sstdn)(load"tee"))(sstdn) $s=x $s=sstdn ^p
[ TEE UP ]^c^c^p(IF (not sstup)(load"tee"))(sstup) $s=x $s=sstup ^p
[REDUCING]
[ TEE FR ]^c^c^p(IF (not frt)(load"tee"))(frt) $s=x $s=frt ^p
[ TEE DN ]^c^c^p(IF (not srtdn)(load"tee"))(srtdn) $s=x $s=srtdn ^p
[ TEE UP ]^c^c^p(IF (not srtup)(load"tee"))(srtup) $s=x $s=srtup ^p
[ CON RED]^c^c^p(IF (not cre)(load"ere"))(cre) $s=x $s=cre ^p
[ ERE RED]^c^c^p(IF (not ere)(load"ere"))(ere) $s=x $s=ere ^p
[~~~~~~~~]
[  GATE  ]^c^c^p(IF (NOT GATVF)(LOAD"GATVF"))(if (= flg_end nil)(setq flg_end "F"))(setq valve-t 1)(gatvf) $s=x $s=gatvf ^p
[ GLOVE  ]^c^c^p(IF (NOT GATVF)(LOAD"GATVF"))(if (= flg_end nil)(setq flg_end "F"))(setq valve-t 2)(gatvf) $s=x $s=glbvf ^p
[ CHECK  ]^c^c^p(IF (NOT CHKVF)(LOAD"CHKVF"))(if (= flg_end nil)(setq flg_end "F"))(setq valve-t 3)(chkvf) $s=x $s=chkvf ^p


