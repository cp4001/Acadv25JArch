(SETQ T (GETSTRING 1 "Tag name...?")) \+
(SETQ N1 (GETSTRING 1 "Tag number1...?")) \+
(SETQ N2 (GETSTRING 1 "Tag number2...?")) \+
(COMMAND "INSERT" "C:/GHK/CISO/TAG8" P1 "1" "1" "0") +
(SETQ T1 (LIST (CAR P1) (+ 1.8 (CADR P1 )))) +
(SETQ T2 (LIST (CAR P1) (+ 1 (CADR P1) -2.2 ))) +
(SETQ T3 (LIST (CAR P1) (+ 1 (CADR P1) -5.3 ))) +
(COMMAND "TEXT" "S" "ISONRM" "C" T1 "2.3" "0" T) +
(COMMAND "TEXT" "C" T2 "2.3" "0" N1) +
(COMMAND "TEXT" "C" T3" 2.3" "0" N2)




