;;;;;; Lucky north mark
(defun lnorth(/ os p1 p2 cird txt1 txt2 ang angb angc a1 a2 a3 p3 p4 p5
                p6 p7 p8 p9 t1 t2 t3 t4 t5 t6 t7 t8 t9 t10 t11 t12 t13
                t14 t15 t16 t17 t18 t19 t20)
    (setq os (getvar "osmode"))
    (setq p1 (getpoint "Inset point:"))
    (setq p2 (getpoint p1 "Direction :"))
    (setvar "osmode" 0)
    (setq cird (* s 20))
    (setq txt1 (* s 2.5))
    (setq txt2 (* s 4))
    (SETQ ang (ANGLE P1 P2))
    (setq angb (+ ang 2.19911))
    (setq angc (- ang 2.19911))
    (setq a1 (- ang 3.14159))
    (setq a2 (+ ang 1.5708))
    (setq a3 (- ang 1.5708))
    (setq p3 (polar p1 a3 (/ cird 2)))
    (setq p4 (polar p1 a2 (/ cird 2)))
    (setq p5 (polar p1 ang (/ cird 2)))
    (setq p6 (polar p1 a1 (/ cird 2)))
    (setq p7 (polar p1 a1 (/ cird 4)))
    (setq p8 (polar p7 angb (* s 6.1965)))
    (setq p9 (polar p7 angc (* s 6.1965)))
    (setq t1 (polar p3 a3 (/ cird 20)))
    (setq t2 (polar p4 a2 (/ cird 20)))
    (setq t3 (polar p5 ang (/ cird 20)))
    (setq t4 (polar p6 a1 (/ cird 20)))
    (setq t5 (polar p1 ang (* cird 0.8)))
    (setq t6 (polar p3 a3 (/ cird 20)))
    (setq t7 (polar p4 a2 (/ cird 20)))
    (setq t8 (polar p5 ang (/ cird 20)))
    (setq t9 (polar p6 a1 (/ cird 20)))
    (setq t10(polar p1 ang (* cird 0.8)))
    (setq t11(polar p3 a3 (/ cird 20)))
    (setq t12(polar p4 a2 (/ cird 20)))
    (setq t13(polar p5 ang (/ cird 20)))
    (setq t14(polar p6 a1 (/ cird 20)))
    (setq t15(polar p1 ang (* cird 0.8)))
    (setq t16(polar p3 a3 (/ cird 20)))
    (setq t17(polar p4 a2 (/ cird 20)))
    (setq t18(polar p5 ang (/ cird 20)))
    (setq t19(polar p6 a1 (/ cird 20)))
    (setq t20(polar p1 ang (* cird 0.8)))
    (command "layer" "s" "5C" "")
    (command "circle" p1 "d" cird)
    (command "pline" p5 "w" "0" "0" p9 p7 p8 p5 "")
    (command "solid" p5 p7 p8 p7 ^c)
    (if (= ang 0)
        (progn
         (command "text" "j" "tc" t1 txt1 "0" "90%%d")
         (command "text" "j" "c" t2 txt1 "0" "270%%d")
         (command "text" "j" "ml" t3 txt1 "0" "0%%d")
         (command "text" "j" "mr" t4 txt1 "0" "180%%d")
         (command "text" "j" "ml" t5 txt2 "0" "PN")
        )
    )
    (if (= (rtd ang) 90)
        (progn
         (command "text" "j" "ml" t6 txt1 "0" "90%%d")
         (command "text" "j" "mr" t7 txt1 "0" "270%%d")
         (command "text" "j" "c" t8 txt1 "0" "0%%d")
         (command "text" "j" "tc" t9 txt1 "0" "180%%d")
         (command "text" "j" "c" t10 txt2 "0" "PN")
        )
    )
    (if (= (rtd ang) 180)
        (progn
         (command "text" "j" "c" t11 txt1 "0" "90%%d")
         (command "text" "j" "tc" t12 txt1 "0" "270%%d")
         (command "text" "j" "mr" t13 txt1 "0" "0%%d")
         (command "text" "j" "ml" t14 txt1 "0" "180%%d")
         (command "text" "j" "mr" t15 txt2 "0" "PN")
        )
    )
    (if (= (rtd ang) 270)
       (progn
         (command "text" "j" "mr" t16 txt1 "0" "90%%d")
         (command "text" "j" "ml" t17 txt1 "0" "270%%d")
         (command "text" "j" "tc" t18 txt1 "0" "0%%d")
         (command "text" "j" "c" t19 txt1 "0" "180%%d")
         (command "text" "j" "tc" t20 txt2 "0" "PN")
       )
    )
    (command "layer" "s" "1E" "")
    (command "line" p4 p3 "")
    (command "layer" "s" la "")
    (setvar "osmode" os)
    (prin1)
)
