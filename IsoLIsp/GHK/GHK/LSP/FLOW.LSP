;;;;;;section down straight tee lisp
(defun drain(/ os p1 p2 piphd flghd ang a1 a2 a3 a4 a5 a6 a7 p3 p4 p5 p6
               p7 p8 p9 p10 p11 p12 la)
    (setq os (getvar "osmode"))
    (setvar "osmode" 512)
    (setq p1 (getpoint "Tee center point [Default = nea point]:"))(terpri)
    (setvar "osmode" 512)
    (setq p2 (getpoint p1 "Select pipe line [Defaulut = nea point]:"))
    (setvar "osmode" 0)
    (IF (= S 30)
        (progn
        (setq piphd 13.7)
        (setq flghd 49.5)
        )
     )
    (IF (= S 50)
        (progn
        (setq piphd 24.1)
        (setq flghd 63.5)
        )
     )
    (IF (= S 100)
        (progn
        (setq piphd 44.5)
        (setq flghd 195.0)
        )
     )
    (SETQ ang (ANGLE P1  P2))
    (setq a1 (- ang (dtr 180)))
    (setq a2 (+ ang (dtr 90)))
    (setq a3 (- ang (dtr 90)))
    (setq a4 (+ ang (dtr 30)))
    (setq a5 (- ang (dtr 30)))
    (setq a6 (+ ang (dtr 150)))
    (setq a7 (- ang (dtr 150)))
    (setq p3 (polar p1 a4 piphd))
    (setq p4 (polar p1 a5 piphd))
    (setq p5 (polar p1 a6 piphd))
    (setq p6 (polar p1 a7 piphd))
    (setq p7 (polar p1 a4 flghd))
    (setq p8 (polar p1 a5 flghd))
    (setq p9 (polar p1 a6 flghd))
    (setq p10(polar p1 a7 flghd))
    (setq p11(polar p1 a2 (* flghd 1.3)))
    (setq p12(polar p1 a3 (* flghd 1.3)))
    (setq la (getvar "clayer"))
    (command "layer" "s" "3C" "")
    (command "arc" "c" p1 p3 p5)
    (command "arc" "c" p1 p6 p4)
    (command "arc" "c" p1 p7 p9)
    (command "arc" "c" p1 p10 p8)
    (command "layer" "s" "1E" "")
    (command "line" p11 p12 "")
    (command "layer" "s" la "")
    (setvar "osmode" os)
    (prin1)
)
;;;;;;section vent straight tee lisp
(defun vent(/ os p1 p2 piphd flghd ang a1 a2 a3 p3 p4 p5 p6
               p7 p8 la)
    (setq os (getvar "osmode"))
    (setvar "osmode" 512)
    (setq p1 (getpoint "Tee center point [Default = nea point]:"))(terpri)
    (setvar "osmode" 512)
    (setq p2 (getpoint p1 "Select pipe line [Defaulut = nea point]:"))
    (setvar "osmode" 0)
    (IF (= S 30)
        (progn
        (setq piphd 13.7)
        (setq flghd 49.5)
        )
     )
    (IF (= S 50)
        (progn
        (setq piphd 24.1)
        (setq flghd 63.5)
        )
     )
    (IF (= S 100)
        (progn
        (setq piphd 44.5)
        (setq flghd 195.0)
        )
     )
    (SETQ ang (ANGLE P1  P2))
    (setq a1 (- ang (dtr 180)))
    (setq a2 (+ ang (dtr 90)))
    (setq a3 (- ang (dtr 90)))
    (setq p3 (polar p1 ang piphd))
    (setq p4 (polar p1 a1 piphd))
    (setq p5 (polar p1 ang flghd))
    (setq p6 (polar p1 a1 flghd))
    (setq p7 (polar p1 a2 (* flghd 1.3)))
    (setq p8 (polar p1 a3 (* flghd 1.3)))
    (setq la (getvar "clayer"))
    (command "break" p1 "f" p5 p6 "")
    (command "layer" "s" "2C" "")
    (command "circle" p1 p3)
    (command "circle" p1 p5)
    (command "layer" "s" "1E" "")
    (command "line" p5 p6 "")
    (command "line" p7 p8 "")
    (command "layer" "s" la "")
    (setvar "osmode" os)
    (prin1)
)
