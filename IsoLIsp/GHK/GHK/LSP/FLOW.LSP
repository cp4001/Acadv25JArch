;;;;;; Revised mark
(defun rev(/ p1 p3 p4 p5 p6 txt1)
    (se3)
    (setq p1 (getpoint  "\nInsert point : "))
    (if (not txt)(setq txt "A"))
    (prompt "Revision No. : < ")
    (princ txt)
    (prompt " > : ")
    (setq txt1(getstring " "))
    (terpri)
    (if (or (= txt1 "")(= txt1 nil))(setq txt txt)(setq txt txt1))
    (setvar "osmode" 0)
    (setq p3 (polar p1 (dtr 90)  (* s 3)))
    (setq p4 (polar p1 (dtr 270) (* s 4)))
    (setq p5 (polar p4 (dtr 0)   (* s 4)))
    (setq p6 (polar p4 (dtr 180) (* s 4)))
    (command "layer" "s" "rev" "")
    (c:lst1)
    (command "pline" p3 "w" "0" "0" p5 p6 "c")
    (command "text" "j" "tc" p1 (* s 2.5) "0" txt)
    (command "move" (ss-add) "" p1 pause)
    (se6)
)
