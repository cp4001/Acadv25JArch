;;;;;; flow mark
(defun flow(/ os sp p1 p2 ang)
    (setq os (getvar "osmode"))
    (setq sp (getvar "snapmode"))
    (setvar "snapmode" 1)
    (setvar "osmode" 512)
    (setq p1 (getpoint "Insert point :"))(print)
    (setvar "osmode" 512)
    (setq p2 (getpoint p1 "Seccond point :"))(print)
    (setvar "osmode" 0)
    (setq ang (angle p1 p2))
    (setq ang (rtd ang))
    (command "insert" "c:/ghk/dwg/flowmark" p1 s s ang)
    (setvar "snapmode" sp)
    (setvar "osmode" os)
)
