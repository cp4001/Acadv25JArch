    (setq s4   p1)
    (setq s4a  (polar s4  ang1 (- (+ vall2 (/ ga 2)) g)))
    (setq s4a1 (polar s4a (+ ang (dtr 180)) flghd))
    (setq s4a2 (polar s4a ang flghd))
    (setq s4b  (polar s4a (+ ang1 (dtr 180)) flgthk))
    (setq s4b1 (polar s4b (+ ang (dtr 180)) flghd))
    (setq s4b2 (polar s4b ang flghd))
    (setq s4b3 (polar s4b (+ ang (dtr 180)) (/ hubdia 2)))
    (setq s4b4 (polar s4b ang (/ hubdia 2)))
    (setq s4c  (polar s4a (+ ang1 (dtr 180)) flglen))
    (setq s4c1 (polar s4c (+ ang (dtr 180)) piphd))
    (setq s4c2 (polar s4c ang piphd))
    (setq s5    (polar s4 (+ ang (dtr 180)) piphd))
    (setq s5a   (polar s5 ang1 piphd))
    (setq s6    (polar s4 ang piphd))
    (setq s6a   (polar s6 ang1 piphd))
    (setq st1   (polar s4 ang (+ vall1 (/ ga 2))))
    (setq st1a  (polar st1 ang1 flghd))
    (setq st11  (polar st1 (+ ang1 (dtr 180)) flghd))
    (setq st2   (polar st1 (+ ang (dtr 180)) flgthk))
    (setq st2a  (polar st1a (+ ang (dtr 180)) flgthk))
    (setq st2b  (polar st2 ang1 (/ hubdia 2)))
    (setq st21  (polar st11 (+ ang (dtr 180)) flgthk))
    (setq st22  (polar st2 (+ ang1 (dtr 180)) (/ hubdia 2)))
    (setq st3   (polar st1 (+ ang (dtr 180)) flglen))
    (setq st3a  (polar st3 ang1 piphd))
    (setq st31  (polar st3 (+ ang1 (dtr 180)) piphd))
    (setq st4   (polar st1 ang flgthk))
    (setq st4a  (polar st1a ang flgthk))
    (setq st41  (polar st11 ang flgthk))
    (setq st5   (polar st4 ang (* len 2)))
    (setq st5a  (polar st4a ang (* len 2)))
    (setq st51  (polar st41 ang (* len 2)))
    (setq sfcen1 (polar s4 (+ ang1 (dtr 180)) (* piphd 1.3)))
    (setq sfcen2 (polar st5 ang (* piphd 0.3)))
    (setq sb1  (polar p1 (+ ang (dtr 180)) vall))
    (setq sb1a (polar sb1 ang1 piphd))
    (setq sb11 (polar sb1 (+ ang1 (dtr 180)) piphd))
    (setq sb4a (polar s4  ang1 vall2))
