(defun strset(/ ppsel pp1sel)
    (pse1)
    (p-data3)
    (p-data4)
    (p-data5 "t-str")
    (endflgtype)
    (if (> vall 1)
        (progn
            (setvar "osmode" 32)
            (setq p1 (getpoint    "\nSelection point :[Default = nea point]:"))
            (setvar "osmode" 0)
            (setq pp (getpoint p1 "\nMaintence Area Direction :"))
            (setq pp1(getpoint p1 "\nDischarge Direction      :"))
            (setq ang (ANGLE P1  Pp))
            (setq ang1(ANGLE P1  Pp1))
            (setq ppsel(ssget (polar p1 (+ ang (dtr 180)) (- len (/ ga 2)))))
            (setq pp1sel(ssget pp1))
            (terpri)
            (prompt "Do you want flange to flange dimension < Default =")
            (princ vall)
            (prompt " > : ")
            (setq vall-1(getreal ""))
            (terpri)
            (if (= vall-1 nil)(setq vall vall)(setq vall vall-1))
            (if (or (= flg_end "F")(= flg_end "W")(= flg_end nil))
                (setq len (+ vall ga))
                (setq len vall)
            )
            (if (/= ppsel nil)
                (command "break" (polar p1 (+ ang (dtr 180)) (- len (/ ga 2))) p1)
            )
            (if (/= pp1sel nil)
                (command "break" (polar p1 ang1 (+ vall2 (/ ga 2))) p1)
            )
            (if (/= flg_end "B")
                (progn
                    (if (not val-flg)(load"c:/ghk/lsp/val-flg"))
                    (val-flg ang (polar p1 (+ ang (dtr 180)) (- len (/ ga 2))))
                    (val-flg (+ ang1 (dtr 180)) (polar p1 ang1 (+ vall2 (/ ga 2))))
                )
            )
            (t-strain)
        )
        (prompt "\n    IS NOT SIZE")
    )
)
