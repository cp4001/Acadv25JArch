    (command "layer" "s" "2C" "")
    (command "pline" st2b "w" "0" "0" st3a st31 st22 st2a st4a st41 st21 st22 "")
    (if (= flg_end "B")
        (progn
            (command "break" sb4a "f" sb4a sfcen1)
            (command "break" sb1 "f" sb1 sfcen2)
            (command "pline" st31 "w" "0" "0" sb11 sb1a s5a sb4a1 sb4a2 s6a st3a "")
            (command "line" st1a st11 "")
            (command "layer" "s" "1E" "")
            (command "line" sfcen1 sb4a "")
            (command "line" sfcen2 sb1 "")
            (weld-mark sb1)
            (weld-mark sb4a)
        )
        (progn
            (command "pline" s2b "w" "0" "0" s3a s31 s22 s2a s1a s11 s21 s22 "")
            (command "pline" s4b3 "w" "0" "0" s4c1 s4c2 s4b4 s4b1 s4a1 s4a2 s4b2 s4b4 "")
