                  st4 st4a st41 st5 st5a st51 sfcen1 sfcen2 sb1 sb1a
                  sb11 sb4a sb4a1 sb4a2)
    (setq s1   (polar p1 (+ ang (dtr 180)) (- len (+ (/ ga 2) g))))
