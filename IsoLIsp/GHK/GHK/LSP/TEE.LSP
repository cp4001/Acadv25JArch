;;;;;;section up straight tee lisp ( D-5 )
(defun sstup(/ p1 p2 ang wdown1)
    (pse1)
    (setvar "osmode" 32)
    (setq p1 (getpoint "\n     Tee center point:[Default = int  point]:"))
    (setvar "osmode" 512)
    (setq p2 (getpoint p1 "\n     Select pipe line:[Default = nea point]:"))
    (SETQ ang (ANGLE P1  P2))
    (sub_tee6)
    (sstup1 ang p2 p1)
    (pse2)
)             ;ang   p2    p1
(defun sstup1(tee-1 tee-2 tee-3 / p4 p41 p42 p5 p51 p52 p6 p61 p62 p7 p8
              p9 p10 p11 p12 p13 pt4)
    (setq tee-type 3)
    (setq ang tee-1)
    (setq p2  tee-2)
    (setq p1  tee-3)
    (p-data1)
    (p-data4)
    (setq p1sel(ssget p1))
    (if (/= p1sel nil)
        (if (= wdown "W")
            (command "break" (polar p1 ang flghd) (polar p1 (+ ang (dtr 180)) flghd))
            (command "break" (polar p1 ang piphd) (polar p1 (+ ang (dtr 180)) piphd))
        )
    )
    (sub_tee3 tee piphd)
    (sub_tee7 p1 (+ ang (dtr 90)))
    (setq tee-type nil)
    (if (/= withval nil)
        (progn
            (setq endang (getangle tee-3 "\n     Valve Direction : "))
            (cond
                ((= ang endang)
                    (endconn-flg pt4 (+ ang (dtr 90)))
                    (endconn-flg p5 (+ ang (dtr 180)))
                    (endconn-val p4 endang)
                )
                ((= (+ ang (dtr 180)) endang)
                    (endconn-flg p4 ang)
                    (endconn-flg pt4 (+ ang (dtr 90)))
                    (endconn-val p5 endang)
                )
                ((= (+ ang (dtr 90)) endang)
                    (endconn-flg p4 ang)
                    (endconn-flg p5 (+ ang (dtr 180)))
                    (endconn-val pt4 endang)
                )
            )
        )
        (progn
            (endconn-flg pt4 (+ ang (dtr 90)))
            (endconn-flg p4 ang)
            (endconn-flg p5 (+ ang (dtr 180)))
        )
    )
)

