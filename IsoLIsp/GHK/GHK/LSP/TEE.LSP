    (pse2)
)
             ;ang   p2    p1
(defun sstdn1(tee-1 tee-2 tee-3 / ang p1 p2 p11 p12 p13 p14 p4 p41 p42 p5
              p51 p52 p1sel cen1 cen2 p2sel p7 p8 p9 p10 p11 p12 p13 p14
              p15 p61 p62 p63 p64)
    (setq tee-type 2)
    (setq ang tee-1)
    (setq p2  tee-2)
    (setq p1  tee-3)
    (p-data1)
    (p-data4)
    (sub_tee3 tee piphd)
    (sub_tee5 p1 (+ ang (dtr 90)) ghk)
    (sub_tee4 piphd flghd ghk)
    (setq tee-type nil)
    (setvar "osmode" 0)
    (if (/= withval nil)
        (progn
            (setq endang (getangle tee-3 "\n     Valve Direction : "))
            (cond
                ((= ang endang)
                    (endconn-val p4 endang)
                    (endconn-flg p5 (+ ang (dtr 180)))
                    (endconn-flg p7 (+ ang (dtr 90)))
                )
                ((= (+ ang (dtr 180)) endang)
                    (endconn-val p5 endang)
                    (endconn-flg p4 ang)
                    (endconn-flg p7 (+ ang (dtr 90)))
                )
                ((= (+ ang (dtr 90)) endang)
                    (endconn-val p7 endang)
                    (endconn-flg p4 ang)
                    (endconn-flg p5 (+ ang (dtr 180)))
                )
            )
        )
        (progn
            (endconn-flg p4 ang)
            (endconn-flg p5 (+ ang (dtr 180)))
            (endconn-flg p7 (+ ang (dtr 90)))
        )
    )
)

