;;;;;;front straight tee lisp ( D-3 )
(defun fst(/ P1 P2 ANG)
    (pse1)
    (setvar "osmode" 33)
    (setq p1 (getpoint "\n     Tee center point:[Default = int point]:"))
    (setvar "osmode" 512)
    (setq p2 (getpoint p1 "\n     Select pipe line:[Default = nea point]:"))
    (SETQ ang (angle P1  P2))
    (fst1 ang p2 p1)
    (pse2)
);;;;;;;;;;;;ang   p2    p1
(defun fst1(tee-1 tee-2 tee-3 / p4 p41p 42 p5 p51 p52 p6 p61 p62)
    (setq tee-type 1)
    (setq ang tee-1)
    (setq p2  tee-2)
    (setq p1  tee-3)
    (p-data1)
    (p-data4)
    (sub_tee1 tee piphd)
    (sub_tee2 tee piphd)
    (setq tee-type nil)
    (setvar "osmode" 0)
    (if (= withval nil)
        (progn
            (endconn-flg p4 ang)
            (endconn-flg p5 (+ ang (dtr 180)))
            (endconn-flg p6 (+ ang (dtr 90)))
        )
        (progn
            (setq endang (getangle p1 "\n     Valve Direction : "))
            (cond
                ((= ang endang)
                    (endconn-val p4 endang)
                    (endconn-flg p5 (+ ang (dtr 180)))
                    (endconn-flg p6 (+ ang (dtr 90)))
                )
                ((= (+ ang (dtr 180)) endang)
                    (endconn-val p5 endang)
                    (endconn-flg p4 ang)
                    (endconn-flg p6 (+ ang (dtr 90)))
                )
                ((= (+ ang (dtr 90)) endang)
                    (endconn-val p6 endang)
                    (endconn-flg p4 ang)
                    (endconn-flg p5 (+ ang (dtr 180)))
                )
            )
        )
    )
)
;;;;;;front reducing tee lisp ( D-6 )
(defun frt(/ p1 p2 ang)
    (pse1)
    (setvar "osmode" 32)
    (setq p1 (getpoint "\n     Tee center point:[Default = int point]:"))
    (setvar "osmode" 512)
    (setq p2 (getpoint p1 "\n     Select pipe line:[Default = nea point]:"))
    (setvar "osmode" 0)
    (setq ang (angle P1  P2))
    (frt1 ang p2 p1)
    (pse2)
);;;;;;;;;;;ang   p2    p1
(defun frt1(tee-1 tee-2 tee-3 / rt piphd2 br-len br-dia br-ghk br-ghk1 p4 p41
            p42 p5  p51 p52 p6 p61 p62 endang)
    (setq tee-type 4)
    (setq ang tee-1)
    (setq p2  tee-2)
    (setq p1  tee-3)
    (p-data1)
    (redtee)
    (if (= ok 1)
        (progn
            (sub_tee1 tee piphd)
            (setq rt(atof br-len))
            (setq br-ghk1 ghk)
            (setq ghk br-ghk)
            (p-data1)
            (sub_tee2 rt piphd)
        )
    )
    (setq tee-type nil)
    (setvar "osmode" 0)
    (if (/= withval nil)
        (progn
            (setq endang (getangle tee-3 "\n     Valve Direction : "))
            (cond
                ((= ang endang)
                    (endconn-flg p6 (+ ang (dtr 90)))
                    (setq ghk br-ghk1)
                    (p-data4)
                    (endconn-flg p5 (+ ang (dtr 180)))
                    (endconn-val p4 endang)
                )
                ((= (+ ang (dtr 180)) endang)
                    (endconn-flg p6 (+ ang (dtr 90)))
                    (setq ghk br-ghk1)
                    (p-data4)
                    (endconn-flg p4 ang)
                    (endconn-val p5 endang)
                )
                ((= (+ ang (dtr 90)) endang)
                    (p-data4)
                    (endconn-val p6 endang)
                    (setq ghk br-ghk1)
                    (endconn-flg p4 ang)
                    (endconn-flg p5 (+ ang (dtr 180)))
                )
            )
        )
        (progn
            (endconn-flg p6 (+ ang (dtr 90)))
            (setq ghk br-ghk1)
            (endconn-flg p4 ang)
            (endconn-flg p5 (+ ang (dtr 180)))
        )
    )
)
;;;;;;section down straight tee lisp ( D-4 )
