    (if (not sa-out)(setq sa-out 150))
    (prompt "Do you want outflange to conter point < ")
    (princ sa-out)
    (prompt " > : ")
    (setq vall2(getreal " "))(terpri)
    (if (or (= vall2 nil) (= vall2 "")) (setq vall2 sa-out)(setq sa-out vall2))
    (p-data3)
    (p-data4)
    (setq p2 (polar p1 (+ ang (dtr 270)) vall1))
    (setq p2sel(ssget p2))
    (if (/= p2sel nil)
        (command "break" p1 p2)
    )
    (command "layer" "s" "1E" "")
    (command "line" p1 p2 "")
    (if (not val-flg)(load"c:/ghk/lsp/val-flg"))
    (val-flg (+ ang (dtr 90)) p2)
    (setq v1 (polar p2 (+ ang (dtr 90)) g))
    (setq v2 (polar v1 ang flghd))
    (setq v3 (polar v1 (+ ang (dtr 180)) flghd))
    (setq h1 (polar p1 (+ ang (dtr 90)) (* vall1 1.2)))
    (setq h2 (polar h1 (+ ang (dtr 90)) (* vall1 0.7)))
    (setq h3 (polar h1 ang flghd))
    (setq h4 (polar h1 (+ ang (dtr 180)) flghd))
    (setq h5 (polar h3 (+ ang (dtr 90)) (* vall1 0.2)))
    (setq h6 (polar h4 (+ ang (dtr 90)) (* vall1 0.2)))
    (setq h7 (polar h5 (+ ang (dtr 90)) (* vall1 0.2)))
    (setq h8 (polar h6 (+ ang (dtr 90)) (* vall1 0.2)))
    (setq h9 (polar h7 (+ ang (dtr 90)) (* vall1 0.2)))
    (command "layer" "s" "2C" "")
    (command "pline" p1 "w" "0" "0" v2 v3 p1 "")
    (command "layer" "s" "5C" "")
    (command "line" p1 h2 "")
    (command "line" h4 h5 "")
    (command "line" h6 h7 "")
    (command "line" h8 h9 "")
    (setq ghk ghk1)
    (ch-size ghk)
    (p-data3)
    (p-data4)
    (setq p2 (polar p1 ang vall2))
    (setq p2sel(ssget p2))
    (if (/= p2sel nil)
        (command "break" p1 p2)
    )
    (command "layer" "s" "1E" "")
    (command "line" p1 p2 "")
    (val-flg (+ ang (dtr 180)) p2)
    (setq v1 (polar p2 (+ ang (dtr 180)) g))
    (setq v2 (polar v1 (+ ang (dtr 90)) flghd))
    (setq v3 (polar v1 (+ ang (dtr 270)) flghd))
    (command "layer" "s" "2C" "")
    (command "pline" p1 "w" "0" "0" v2 v3 p1 "")
    (setq ghk1 nil)
    (RESETGHK)
    (pse2)
)
