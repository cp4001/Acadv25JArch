(defun safety(/ a-pip k-pip flglen flgd flgthk hubdia flghd stubl stubl1
                stubd p1 pp ang vall1 vall2 p2 p2sel v1 v2 v3 h1 h2 h3
                h4 h5 h6 h7 h8 h9)
    (pse1)
    (setvar "osmode" 32)
    (setq p1 (getpoint "\n Selection point:[Default = int point]:"))
    (setvar "osmode" 512)
    (setq pp (getpoint p1 "\n Second point:[Default = nea point]:"))
    (setvar "osmode" 0)
    (SETQ ang (ANGLE P1  Pp))
    (redsafety)
    (face-dim)
    (if (not sa-inl)(setq sa-inl 150))
    (prompt "Do you want inletflange to conter point < ")
    (princ sa-inl)
    (prompt " > : ")
    (setq vall1(getreal " "))(terpri)
