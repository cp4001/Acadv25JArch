    (setvar "osmode" 0)
    (SETQ ang(ANGLE P1  P2))
    (p-data1)
    (if (not redtee)(load"c:/ghk/lsp/tee"))
    (redtee)
    (if (= ok 1)
        (progn
            (setq rt(atof br-len))
            (setq piphd2(/ (atof br-dia) 2))
            (setq p3 (polar p2 ang red))
            (setq p4 (polar p2 (+ ang (dtr 270)) piphd))
            (setq p5 (polar p2 (+ ang (dtr 90)) piphd))
            (setq p6 (polar p3 (+ ang (dtr 270)) piphd2))
            (setq p7 (polar p3 (+ ang (dtr 90)) piphd2))
            (if (/= p2sel nil)
                (command "break" p1 "f" p2 p3 )
            )
            (ls2)
