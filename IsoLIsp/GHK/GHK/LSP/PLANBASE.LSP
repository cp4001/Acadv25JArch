(defun p-data4(/ lst1 lst1- lst10 lst10- lst11 flglen1 flglen2)
    (p-data "flg")
    (ch-size ghk)
    (setq lst1- (nth (atoi sizenum) lst1));size select
    (setq lst10(nth 0 lst1-));WN flg
    (cond
        ((= rat "A")
            (setq lst10-(nth 0 lst10));150#
        )
        ((= rat "B")
            (setq lst10-(nth 1 lst10));300#
        )
        ((= rat "C")
            (setq lst10-(nth 2 lst10));600#
        )
        ((= rat "D")
            (setq lst10-(nth 3 lst10));900#
        )
        ((= rat "E")
            (setq lst10-(nth 4 lst10));1500#
        )
        ((= rat "F")
            (setq lst10-(nth 5 lst10));2500#
        )
    )
    ;     wnf len                      sof len                      flgdia
    (setq flglen1(atof (nth 0 lst10-)) flglen2(atof (nth 1 lst10-)) flgd(atof (nth 2 lst10-))
          flgthk(atof (nth 3 lst10-)) hubdia(atof (nth 4 lst10-)) flghd (/ flgd 2.0)
    )    ;sof wnfthk                  wnfhub
    (if (= sd "W")
        (setq flglen flglen1)
        (setq flglen flglen2)
    )
    (setq lst11(nth 1 lst1-));Stub end
    (setq stubl(atof (nth 0 lst11)) stubl1(atof (nth 1 lst11)) stubd(atof (nth 2 lst11)))
)

(defun p-data5(data1 / lst1 lst1- lst10 lst10-)
    (p-data data1)
    (ch-size ghk)
    (setq lst1- (nth (atoi sizenum) lst1));size select
    (if (/= lst1- nil)
        (pset2)
    )
    (if (or (= lst10- nil) (= lst1- nil))
        (setq vall 0 vall1 0 vall2 0)
        (progn
            (setq vall(atof (nth 0 lst10-)))
            (setq vall1(nth 1 lst10-))
            (if (= vall1 nil)
                (setq vall1 0 vall2 0)
                (setq vall1(atof (nth 1 lst10-)) vall2(atof (nth 2 lst10-)))
            )
        )
    )
    (if (or (= flg_end "F")(= flg_end "W")(= flg_end nil))
        (setq len (+ vall ga))
        (setq len vall)
    )
)

