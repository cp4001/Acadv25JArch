(defun valset()
    (setq dcl_id (load_dialog "valset.dcl"))
    (if (not old_point)(setq old_point '(640 480)))
    (if (not (new_dialog "valset" dcl_id "" old_point))
        (exit)
    )
    (start_image "image1")
    (slide_image 0 0 (dimx_tile "image1") (dimy_tile "image1")  "c:/ghk/lsp/diatype")
    (end_image)
    (start_image "image2")
    (slide_image 0 0 (dimx_tile "image2") (dimy_tile "image2") "c:/ghk/lsp/buttype")
    (end_image)
    (cond ((= 1 dia-type) (set_tile "zdia1" "1"))
          ((= 2 dia-type) (set_tile "zdia2" "1"))
    )
    (cond ((= 1 but-type) (set_tile "zbut1" "1"))
          ((= 2 but-type) (set_tile "zbut2" "1"))
    )
    (action_tile "accept" "(progn (setq x $x y $y) (setq old_point (done_dialog 1)))")
    (action_tile "zdia1" "(setq dia-type 1)")
    (action_tile "zdia2" "(setq dia-type 2)")
    (action_tile "zbut1" "(setq but-type 1)")
    (action_tile "zbut2" "(setq but-type 2)")
    (setq ok(start_dialog))
    (done_dialog)
    (unload_dialog dcl_id)
    (princ)
)

(defun minpipe()
    (cond
        ((< ghk 66)
            (setq minpip 30)
        )
        ((< ghk 251)
            (setq minpip 50)
        )
        ((< ghk 401)
            (setq minpip 70)
        )
        ((> ghk 402)
            (setq minpip 90)
        )
    )
)
(defun weld-mark(mark1)
    (command "layer" "s" "1C" "")
    (if (< ghk large)
        (command "insert" "c:/ghk/dwg/p-weld1" mark1 weld1 weld1 "0")
        (command "insert" "c:/ghk/dwg/p-weld2" mark1 weld2 weld2 "0")
    )
)
;;;;;;;;;;;;;;;;;;;p1      ang
(defun endconn-flg(endcon1 endcon2 / endpoint endang p4sel)
    (if (= withflg "ON")
        (progn
            (p-data1)
            (p-data4)
            (minpipe)
            (setq p4sel nil)
            (if (= sd "S")
                (setq endpoint(polar endcon1 endcon2 (+ flglen minpip weldc)))
                (if (= sd "L")
                    (setq endpoint(polar endcon1 endcon2 (+ stubl weldc)))
                    (setq endpoint(polar endcon1 endcon2 (+ flglen weldc)))
                )
            )
            (ls1)
            (setq p4sel(ssget endpoint))
            (if (< ghk double)(command "line" endcon1  endpoint ""))
            (setq endang endcon2)
            (if (not val-flg)(load"c:/ghk/lsp/val-flg"))
            (val-flg endang endpoint)
            (if (>= ghk double)
                (val-flg (+ endang (dtr 180)) endpoint)
                (progn
                    (if (/= p4sel nil)
                        (command "break" (polar endpoint endang (* g 1.5)) endpoint)
                    )
                    (command "layer" "s" "1E" "")
                    (command "line" endpoint (polar endpoint endang (* g 1.5)) "")
                    (val-flg (+ endang (dtr 180)) (polar endpoint endang (* g 1.5)))
                )
            )
        )
    )
)

;;;;;;;;;;;;;;;;;;;p1      ang
(defun endconn-val(endcon1 endcon2 / endpoint endang)
    (setq val-view 2)
    (setq job_direc 1)
    (minpipe)
    (if (= sd "S")
        (setq endpoint (polar endcon1 endcon2 (+ flglen minpip  weldc)))
        (if (= sd "L")
            (setq endpoint(polar endcon1 endcon2 (+ stubl weldc)))
            (setq endpoint(polar endcon1 endcon2 (+ flglen weldc)))
        )
    )
    (setq endang endcon2)
    (cond
        ((= withval 1)
            (setq valve-t 1)
            (if (not gatvf)(load"c:/ghk/lsp/gatvf"))
            (gatvf)
        )
        ((= withval 2)
            (setq valve-t 2)
            (if (not gatvf)(load"c:/ghk/lsp/gatvf"))
            (gatvf)
        )
        ((= withval 3)
            (if (not chkvf)(load"c:/ghk/lsp/chkvf"))
            (chkvf)
        )
        ((= withval 4)
            (if (not balvf)(load"c:/ghk/lsp/balvf"))
            (balvf)
        )
        ((= withval 5)
            (if (not diavf)(load"c:/ghk/lsp/diavf"))
            (diavf)
        )
        ((= withval 6)
            (if (not butvf)(load"c:/ghk/lsp/butvf"))
            (butvf)
        )
    )
    (setq withval nil)
)

(defun entt-ch(entt1 / en el c-layer b1)
    (setq en(ssname (ssget "l") 0))
    (setq el(entget en))
    (setq c-layer (assoc 8 el))
    (setq b1 (subst (cons (car c-layer) entt1) c-layer el))
    (entmod b1)
)
(defun entt-ch1(entt1 entt2 entt3 / en el point-1 b1)
    (setq en(ssname entt1 0))
    (setq el(entget en))
    (if (equal entt2 (cdr (assoc 10 el)))
        (setq point-1 (assoc 10 el))
        (if (equal entt2 (cdr (assoc 11 el)))
            (setq point-1 (assoc 11 el))
            (if (equal (angle entt2 entt3) (angle entt2 (cdr (assoc 10 el))))
                (setq point-1 (assoc 11 el))
                (setq point-1 (assoc 10 el))
            )
        )
    )
;    (if (or (equal (angle entt2 entt3) (angle entt2 (cdr (assoc 10 el))))
;            (equal entt2 (cdr (assoc 10 el))))
    (setq b1 (subst (cons (car point-1) entt3) point-1 el))
    (entmod b1)
)
