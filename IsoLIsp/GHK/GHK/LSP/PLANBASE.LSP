;Data file read
(defun p-data(file / fn n-line if1)
	(setq lst1 nil lst2 nil)
 
       (setq fn(open (strcat "c:/ghk/lsp/" file".dat") "r"))
       (setq msg(read-line fn))
       (while (setq n-line(read-line fn))
              (setq if1(substr n-line 1 1))
              (cond ((= if1 "*")
                     (setq lst2(cons (substr n-line 2) lst2))
                    )
                    ((= if1 "(")
                     (setq lst1(cons (read n-line) lst1))
                    )
              )
       )
       (setq lst1(reverse lst1) lst2(reverse lst2))
)

(defun p-data1(/ lst1 lst1- sw3 bw)
    (p-data "pipe")
    (if (< S 40)
        (if (< ghk 40)(setq sizenum "3")(ch-size ghk))
        (if (< s 90)
            (if (< ghk 50)(setq sizenum "4")(ch-size ghk))
            (if (< ghk 125)(setq sizenum "8")(ch-size ghk))
        )
    )
    (setq lst1- (nth (atoi sizenum) lst1))
    (if (< ghk sock)
        (progn
            (setq sw3 (nth 1 lst1-))
            (setq elbow90l(atof (nth 0 sw3)) elbow90s(atof (nth 1 sw3)) elbow45(atof (nth 2 sw3))
                  tee(atof (nth 3 sw3)) cplg(atof (nth 4 sw3)) cap(atof (nth 5 sw3))
                  swg(atof (nth 6 sw3)) a-pip(atof (nth 11 sw3)) k-pip(atof (nth 12 sw3))
            )
        )
        (progn
            (setq bw (nth 0 lst1-))
            (setq elbow90l(atof (nth 0 bw)) elbow90s(atof (nth 1 bw)) elbow45(atof (nth 2 bw))
                  tee(atof (nth 3 bw)) red(atof (nth 4 bw)) cap(atof (nth 5 bw)) swg(atof (nth 6 bw))
                  a-pip(atof (nth 10 bw)) k-pip(atof (nth 11 bw))
            )
        )
    )
    (pset1)
)

(defun p-data2(/ lst1 lst1- sw3 bw)
    (p-data "pipe")
    (if (< S 40)
        (if (< ghk 80)(setq sizenum "6")(ch-size ghk))
        (if (< s 90)
            (if (< ghk 100)(setq sizenum "7")(ch-size ghk))
            (if (< ghk 150)(setq sizenum "9")(ch-size ghk))
        )
    )
    (setq lst1- (nth (atoi sizenum) lst1))
    (if (< ghk sock)
        (progn
            (setq sw3 (nth 1 lst1-))
            (setq a-pip(atof (nth 11 sw3)) k-pip(atof (nth 12 sw3)))
        )
        (progn
            (setq bw (nth 0 lst1-))
            (setq a-pip(atof (nth 10 bw)) k-pip(atof (nth 11 bw)))
        )
    )
    (pset1)
)

(defun p-data3(/ lst1 lst1- sw3 bw)
