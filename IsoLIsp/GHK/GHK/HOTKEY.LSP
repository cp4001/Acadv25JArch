(defun c:SR(/ pt1 pt2 pt3 pt4 pt5 pt6 tot)
   (setvar "cmdecho" 0)
   (setq os(getvar "osmode"))
   (setvar "osmode" 37)
   (while (setq pt1 (getpoint "\nFirst corner :"))
          (setq pt2 (getcorner pt1"\nOther corner :")
                tot (cons (cons pt1 pt2) tot)
                pt3 (list (car pt2) (cadr pt1))
                pt4 (list (car pt1) (cadr pt2))      )
                (grdraw pt1 pt3 6 1) (grdraw pt3 pt2 6 1)
                (grdraw pt2 pt4 6 1) (grdraw pt4 pt1 6 1)
   )
   (setq pt5 (getpoint "\nBase point :")
         pt6 (getpoint pt5 "\nNew point :")
         tot (reverse tot)
   )
   (setvar "osmode" 0)
   (foreach x tot  (command "stretch" "c" (car x) (cdr x) "" pt5 pt6))
   (setvar "osmode" os)
   (redraw) (princ)
)

