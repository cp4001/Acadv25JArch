(defun c:co (/ la orth os p1 p2 r1 p3 p4 p5 p6 p7 p8 p9)
    (setq la (getvar "clayer"))
    (setq orth(getvar "orthomode"))
    (setq os(getvar "osmode"))
    (setvar "osmode" 0)
    (setq p1 (getpoint"\nFirst Point")
          p2 (getpoint p1 "\nSecond Point")
          r1 (angle p1 p2)
          p3 (polar p1 r1 (* (distance p1 p2) 0.5))
          p4 (polar p3 (+ r1 (dtr 180)) (* s 0.5))
          p5 (polar p4 (+ r1 (dtr 180)) (* s 0.5))
          p6 (polar p4 (+ r1 (dtr 90))  (* s 4))
          p7 (polar p3 r1               (* s 0.5))
          p8 (polar p7 r1               (* s 0.5))
          p9 (polar p7 (+ r1 (dtr 270)) (* s 4))
     )
    (command "layer" "s" "1C" "")
    (command "pline" p1 p5 p6 p9 p8 p2 "")
    (setvar "orthomode" orth)
    (setvar "osmode" os)
    (command "layer" "s" la "")
)

(defun c:co1 (/ la orth os p1 p2 r1 p3 p4)
    (setq la (getvar "clayer"))
    (setq orth(getvar "orthomode"))
    (setq os(getvar "osmode"))
    (setvar "osmode" 33)
    (setq p1 (getpoint"\nFirst Point")
          p2 (getpoint p1 "\nSecond Point")
          r1 (angle p1 p2)
          p3 (polar p1 r1 (/ (distance p1 p2) 2))
          p4 (polar p3 (+ r1 (dtr 90))  (/ (distance p1 p2) 6))
    )
    (setvar "osmode" 0)
    (command "layer" "s" "1C" "")
    (command "pline" p1 p4 p2 "")
    (setvar "orthomode" orth)
    (setvar "osmode" os)
    (command "layer" "s" la "")
)

(defun c:co2 (/ la orth os p1 p2)
    (setq la (getvar "clayer"))
    (setq orth(getvar "orthomode"))
    (setq os(getvar "osmode"))
    (setvar "osmode" 33)
    (setq p1 (getpoint"\nFirst Point")
          p2 (getpoint p1 "\nSecond Point")
    )
    (co2_sub p1 p2)
    (setvar "orthomode" orth)
    (setvar "osmode" os)
    (command "layer" "s" la "")
)
(defun co2_sub (p1 p2 / r1 p3 p4 p5 p6 p7 p8 p9)
    (setq r1 (angle p1 p2)
          p3 (polar p1 r1 (/ (distance p1 p2) 2))
          p4 (polar p3 r1 (* s 0.5))
          p5 (polar p4 r1 (* s 0.5))
          p6 (polar p4 (+ r1 (dtr 90))  (* s 0.5))
          p7 (polar p3 (+ r1 (dtr 180))  (* s 0.5))
          p8 (polar p7 (+ r1 (dtr 180))  (* s 0.5))
          p9 (polar p7 (+ r1 (dtr 270))  (* s 0.5))
    )
    (setvar "osmode" 0)
    (command "layer" "s" "1C" "")
    (command "line" (polar p1 (+ r1 (dtr 180)) (* s 2)) p8 "" "line" p5 (polar p2 r1 (* s 2)) "")
    (command "arc" p9 p8 p3 "arc" p3 p5 p6)
)

