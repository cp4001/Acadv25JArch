(defun c:bs1 (/ pnt1 pnt2 pnt3 pnt4 pnt5 pnt6 wl hl)
  (se3)
  (setvar "osmode" 32)
  (setq pnt1 (getpoint "Base point of Baseplate :")) (terpri)
  (setq wl   (getreal "Width Length [mm]:")) (terpri)
  (setq hl   (getreal "Hight Length [mm]:")) (terpri)
  (setq pnt2 (polar pnt1 (dtr 90) (/ hl 2)))
  (setq pnt3 (polar pnt2 (dtr 180) (/ wl 2)))
  (setq pnt4 (polar pnt3 (dtr 270) hl))
  (setq pnt5 (polar pnt4 (dtr 0) wl))
  (setq pnt6 (polar pnt5 (dtr 90) hl))
  (setvar "osmode" 0)
  (command "layer" "s" "5c" "")
  (command "pline" pnt3 "w" "0" "0" pnt4 pnt5 pnt6 "c")
  (command "layer" "s" "1e" "")
  (command "line" (polar pnt1 (dtr 90) (/ hl 1.8)) (polar pnt1 (dtr 270) (/ hl 1.8)) "")
  (command "line" (polar pnt1 (dtr 180) (/ wl 1.8)) (polar pnt1 (dtr 0) (/ wl 1.8)) "")
  (command "layer" "s" la "")
  (setvar "osmode" os)
)


(defun C:B2(/ os ww sno pt1 pt2 no x jjent)
    (setvar "cmdecho" 0)
    (setq os (getvar "osmode"))
    (setvar "osmode" 37)
    (princ " = BREAK2P")
    (graphscr)
    (setq ww (ssget))
    (setq sno (sslength ww))
    (setq pt1 (getpoint "\nEnter 1st Point : "))
    (setq pt2 (getpoint pt1 "\nEnter 2nd Point : "))
    (setvar "osmode" 0)
    (setq no 0)
    (repeat sno
        (setq x (ssname ww no))
        (setq jjent(cdr (assoc 0 (entget x))))
        (if (or (= "LINE" jjent) (= "LWPOLYLINE" jjent))
            (command "break" x pt1 pt2)
        )
        (setq no (1+ no))
    )
    (setvar "osmode" os)
    (prin1)
)


