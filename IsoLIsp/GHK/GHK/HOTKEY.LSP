(defun C:le(/ orth os dim_block dim_asz p1 p2)
    (setvar "cmdecho" 0)
    (setq la (getvar "clayer"))
    (command "layer" "s" "1C" "")
    (princ " = DIM <Leader> ")
    (setq orth (getvar "ORTHOMODE"))
    (setq os(getvar "osmode"))
    (setq dim_block (getvar "dimblk"))
    (setq dim_asz (getvar "dimasz"))
    (command "dimasz" 2.5)
    (command "dim" "dimblk" "." "e")
    (command "orthomode" "0")
    (command "osmode" "512")
    (setq p1 (getpoint "1st point:"))(terpri)
    (setq p2 (getpoint p1 "2nd point:"))(terpri)
    (command "dim" "LEA" p1 p2 "" ^c "e")(prin1)
    (command "orthomode" orth)
    (setvar "osmode" os)
    (command "dim" "dimblk" dim_block "e")
    (command "dimasz" dim_asz)
    (command "layer" "s" la "")
)


