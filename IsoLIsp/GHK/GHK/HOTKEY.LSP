(defun c:b1(/ p1 p2 a a1 a2 a3 di d2 p3 p4 p31 p41)
    (se3)
    (setvar "osmode" 1)
    (setq p1 (getpoint "First point:"))
    (setvar "osmode" 1)
    (setq p2 (getpoint p1 "Second point:"))
    (setvar "osmode" 0)
    (command "dist" p1 p2 )
    (SETQ A (ANGLE p1 p2))
    (setq a1 (- a 3.14159))
    (setq a2 (- a 1.5708))
    (setq a3 (+ a 1.5708))
    (setq di (getvar "distance"))
    (setq di (/ di 3))
    (setq d2 (/ di 3))
    (setq p3 (polar p1 a di))
    (setq p4 (polar p3 a di))
    (setq p31(polar p3 a2 d2))
    (setq p41(polar p4 a3 d2))
    (command "layer" "s" "2C" "")
    (command "pline" p1 "w" "0" "0" p31 p41 p2 "")
    (command "pedit" "l" "s" "")
    (command "layer" "s" la "")
    (setvar "osmode" os)
    (prin1)
)
(defun C:DA(/ P1 P2 ang p3 p4 p5)
    (se3)
    (command "osmode" "32")
    (setq p1 (getpoint "Dimansion Base point :"))(print)
    (command "osmode" "0")
    (setq p2 (getpoint p1 "Dimansion Offset Direction :"))(print)
    (setq ang (angle p1 p2))
    (setq p3 (polar p1 ang (* s 20)))
    (setq p4 (polar p3 ang (* s 10)))
    (setq p5 (polar p4 ang (* s 10)))
    (command "layer" "s" "2C" "")
    (command "line" (polar p3 ang (* s 3)) (polar p3 (+ ang (dtr 180)) (* s 3)) "")
    (command "line" (polar p3 (+ ang (dtr 90)) (* s 3)) (polar p3 (+ ang (dtr 270)) (* s 3)) "")
    (command "line" (polar p4 ang (* s 3)) (polar p4 (+ ang (dtr 180)) (* s 3)) "")
    (command "line" (polar p4 (+ ang (dtr 90)) (* s 3)) (polar p4 (+ ang (dtr 270)) (* s 3)) "")
    (command "line" (polar p5 ang (* s 3)) (polar p5 (+ ang (dtr 180)) (* s 3)) "")
    (command "line" (polar p5 (+ ang (dtr 90)) (* s 3)) (polar p5 (+ ang (dtr 270)) (* s 3)) "")
    (se6)
    (prin1)
)

(defun c:te(/ sum i sss l en el text1 text k1 d1 b1)
    (setvar "cmdecho" 0)
    (setq sum 0)
    (setq i 0)
    (setq sss(ssget))
    (setq l(sslength sss))
    (repeat l
        (setq en(ssname sss i))
        (setq el (entget en))
        (setq e_text (assoc 0 el))
        (if (or (= (cdr e_text) "DIMENSION") (= (cdr e_text) "TEXT") (= (cdr e_text) "MTEXT"))
            (progn
                (setq text1 (assoc 1 el))
                (setq text (cdr (assoc 1 el)))
                (prompt "\nOld text: ") (princ text)(terpri)
                (prompt "New text: ")
                (setq k1(getstring 5 ))
                (if (= k1 "")
                    (setq k1 text)
                )
                (setq d1(cons (car text1) k1))
                (setq b1 (subst d1 text1 el))
                (entmod b1)
            )
        )
        (setq i(+ 1 i))
    )
)

