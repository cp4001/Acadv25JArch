(defun C:HH1(/ sss high1 l i en b c d b1 C1)
    (if (not high)(setq high (* s 2.5)))
    (setq sss(ssget))
    (terpri)
    (prompt " Text Hight : <DEFAULT = ")
    (princ high)
    (prompt " > : ")
    (setq high1(getreal " "))
    (terpri)
    (if (= high1 nil)(setq high1 high)(setq high high1))
    (setq l(sslength sss))
    (setq i 0)
    (repeat l
        (setq en(ssname sss i))
        (setq b (entget en))
        (setq c (assoc 40 b))
        (setq c1 (assoc 0 b))
        (if (= (cdr c1) "TEXT")
         (progn
            (setq d (cons (car c) high1))
            (setq b1 (subst d c b))
            (entmod b1)
         )
        )
        (setq i(+ 1 i))
    )
)

