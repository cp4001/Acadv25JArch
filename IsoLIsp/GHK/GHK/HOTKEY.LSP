(defun c:bo (/ pnt1 pnt2 pnt3 pnt4)
  (se3)
  (setvar "osmode" 32)
  (setq pnt1 (getpoint "First corner of rectangle")) (terpri)
  (setq pnt3 (getcorner pnt1 "Seccond corner of rectangle")) (terpri)
  (setq pnt2 (list (car pnt1) (cadr pnt3)))
  (setq pnt4 (list (car pnt3) (cadr pnt1)))
  (command "layer" "s" "1p" "")
  (command "pline" pnt1 "w" "0" "0" pnt2 pnt3 pnt4 "c")
  (command "layer" "s" la "")
  (setvar "osmode" os)
)

