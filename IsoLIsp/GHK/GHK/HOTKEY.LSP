(defun C:tr(/ sss t_angle1 l i en b c d b1 C1)
    (if (not t_angle)(setq t_angle 0))
    (setq sss(ssget))
    (terpri)
    (prompt " Text Angle : <Default = ")
    (princ t_angle)
    (prompt " > : ")
    (setq t_angle1(getreal " "))
    (terpri)
    (if (= t_angle1 nil)(setq t_angle1 t_angle)(setq t_angle t_angle1))
    (setq l(sslength sss))
    (setq i 0)
    (repeat l
        (setq en(ssname sss i))
        (setq b (entget en))
        (setq c (assoc 50 b))
        (setq c1 (assoc 0 b))
        (if (or (= (cdr c1) "TEXT")(= (cdr c1) "MTEXT"))
         (progn
            (setq d (cons (car c) (dtr t_angle1)))
            (setq b1 (subst d c b))
            (entmod b1)
         )
        )
        (setq i(+ 1 i))
    )
)

